  description String?
  moduleKey   String
  isActive    Boolean  @default(true)
  createdById String
  createdBy   User     @relation("ApprovalFlowCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps    ApprovalStep[]
  requests ApprovalRequest[]

  @@index([companyId])
  @@index([moduleKey])
}

model ApprovalStep {
  id             String       @id @default(uuid())
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  approvalFlowId String
  approvalFlow   ApprovalFlow @relation(fields: [approvalFlowId], references: [id], onDelete: Cascade)
  stepOrder      Int
  approverType   ApproverType
  approverValue  String
  required       Boolean      @default(true)
  createdAt      DateTime     @default(now())
}

model ApprovalRequest {
  id             String         @id @default(uuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  approvalFlowId String
  approvalFlow   ApprovalFlow   @relation(fields: [approvalFlowId], references: [id], onDelete: Cascade)
  entityType     String
  entityId       String
  requesterId    String
  requester      User           @relation("ApprovalRequester", fields: [requesterId], references: [id])
  currentStep    Int            @default(1)
  status         ApprovalStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  history ApprovalHistory[]

  @@index([companyId])
  @@index([entityType])
  @@index([entityId])
  @@index([status])
}

model ApprovalHistory {
  id                String          @id @default(uuid())
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  approvalRequestId String
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  action            ApprovalAction
  comment           String?
  createdAt         DateTime        @default(now())

  @@index([approvalRequestId])
}

model ReportTemplate {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  moduleKey     String
  dataSource    String
  configuration Json
  isActive      Boolean  @default(true)
  createdById   String
  createdBy     User     @relation("ReportTemplateCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  permissions ReportPermission[]
  executions  ReportExecution[]
  schedules   ScheduledReport[]

  @@index([companyId])
  @@index([moduleKey])
}

model ReportPermission {
  id             String               @id @default(uuid())
  reportId       String
  report         ReportTemplate       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role                 @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionType ReportPermissionType
}

model ReportExecution {
  id            String                @id @default(uuid())
  companyId     String
  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportId      String
  report        ReportTemplate        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User                  @relation("ReportExecutionRequester", fields: [requestedById], references: [id])
  format        ReportFormat
  status        ReportExecutionStatus @default(PENDING)
  fileUrl       String?
  parameters    Json?
  createdAt     DateTime              @default(now())
  completedAt   DateTime?

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model ScheduledReport {
  id         String         @id @default(uuid())
  companyId  String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportId   String
  report     ReportTemplate @relation(fields: [reportId], references: [id], onDelete: Cascade)
  schedule   String
  recipients Json
  isActive   Boolean        @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  createdAt  DateTime       @default(now())

  @@index([companyId])
  @@index([nextRunAt])
}

model ApiKey {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String
  secretHash  String
  permissions Json?
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)
  createdById String
  createdBy   User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([companyId])
  @@index([keyHash])
}

model Webhook {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  url         String
  eventKey    String
  secret      String
  isActive    Boolean  @default(true)
  createdById String
  createdBy   User     @relation("WebhookCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([companyId])
  @@index([eventKey])
}

model WebhookDelivery {
  id           String        @id @default(uuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  webhookId    String
  webhook      Webhook       @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventKey     String
  payload      Json?
  status       WebhookStatus @default(PENDING)
  responseCode Int?
  responseBody String?
  attempts     Int           @default(0)
  createdAt    DateTime      @default(now())
  completedAt  DateTime?

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

enum BranchRoleType {
  MANAGER
  STAFF
  VIEWER
}

model Branch {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String
  address   String?
  phone     String?
  email     String?
  managerId String?
  manager   User?    @relation("BranchManager", fields: [managerId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branchUsers       BranchUser[]
  branchPermissions BranchPermission[]
  warehouses        Warehouse[]
  journalEntries    JournalEntry[]
  ledgerEntries     LedgerEntry[]

  @@index([companyId])
  @@index([code])
}

model BranchUser {
  id        String         @id @default(uuid())
  branchId  String
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleType  BranchRoleType
  createdAt DateTime       @default(now())

  @@index([branchId])
  @@index([userId])
}

model BranchPermission {
  id           String     @id @default(uuid())
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([branchId])
  @@index([roleId])
}

model InventoryTransaction {
  id              String                   @id @default(uuid())
  companyId       String
  company         Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId     String
  warehouse       Warehouse                @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId       String?
  transactionType InventoryTransactionType
  quantity        Decimal
  referenceType   String
  referenceId     String?
  createdById     String
  createdBy       User                     @relation("InventoryTransactionCreator", fields: [createdById], references: [id])
  createdAt       DateTime                 @default(now())

  @@index([companyId])
  @@index([warehouseId])
  @@index([createdAt])
}

model StockTransfer {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transferNumber  String
  fromWarehouseId String
  fromWarehouse   Warehouse @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse @relation("TransferTo", fields: [toWarehouseId], references: [id])
  requestedById   String
  requestedBy     Employee  @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedById    String?
  approvedBy      Employee? @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  status          String    @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, IN_TRANSIT, PARTIALLY_RECEIVED, COMPLETED, CANCELLED
  transferDate    DateTime?
  remarks         String?

  lines StockTransferLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, transferNumber])
  @@index([companyId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model StockTransferLine {
  id              String        @id @default(uuid())
  stockTransferId String
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])

  batchId  String?
  batch    InventoryBatch?  @relation(fields: [batchId], references: [id])
  serialId String?
  serial   InventorySerial? @relation(fields: [serialId], references: [id])

  fromZoneId String?
  fromZone   WarehouseZone? @relation("TransferFromZone", fields: [fromZoneId], references: [id])
  toZoneId   String?
  toZone     WarehouseZone? @relation("TransferToZone", fields: [toZoneId], references: [id])
  fromBinId  String?
  fromBin    WarehouseBin?  @relation("TransferFromBin", fields: [fromBinId], references: [id])
  toBinId    String?
  toBin      WarehouseBin?  @relation("TransferToBin", fields: [toBinId], references: [id])

  quantity         Decimal
  receivedQuantity Decimal @default(0)
  remarks          String?

  @@index([stockTransferId])
  @@index([productId])
}

model AnalyticsSnapshot {
  id          String   @id @default(uuid())
  companyId   String
