  companyId   String
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        InsightType
  title       String
  description String          @db.Text
  severity    InsightSeverity
  metadata    Json?
  isRead      Boolean         @default(false)
  userId      String?
  user        User?           @relation(fields: [userId], references: [id])
  createdAt   DateTime        @default(now())

  @@index([companyId])
  @@index([type])
  @@index([isRead])
}

model ForecastRecord {
  id             String   @id @default(uuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  metricKey      String
  forecastPeriod String
  predictedValue Decimal?
  confidence     Decimal?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([companyId])
  @@index([metricKey])
  @@index([forecastPeriod])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalType {
  GENERAL
  SALES
  PURCHASE
  CASH
  BANK
  PAYROLL
}

model ChartOfAccount {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountCode String
  accountName String
  accountType AccountType
  parentId    String?
  parent      ChartOfAccount?  @relation("ChartOfAccountParent", fields: [parentId], references: [id])
  children    ChartOfAccount[] @relation("ChartOfAccountParent")
  isSystem    Boolean          @default(false)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  journalEntryLines JournalEntryLine[]
  ledgerEntries     LedgerEntry[]

  @@unique([companyId, accountCode])
  @@index([companyId])
  @@index([accountCode])
}

model FiscalYear {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())

  periods AccountingPeriod[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([isClosed])
}

model AccountingPeriod {
  id           String     @id @default(uuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId String
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  name         String
  startDate    DateTime
  endDate      DateTime
  isClosed     Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@unique([companyId, fiscalYearId, name])
  @@index([companyId])
  @@index([fiscalYearId])
}

model Journal {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code        String
  name        String
  journalType JournalType
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  journalEntries JournalEntry[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([code])
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
  CANCELLED
}

model JournalEntry {
  id            String             @id @default(uuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?            @relation(fields: [branchId], references: [id])
  journalId     String
  journal       Journal            @relation(fields: [journalId], references: [id])
  entryNumber   String
  entryDate     DateTime
  description   String?
  referenceType String?
  referenceId   String?
  status        JournalEntryStatus @default(DRAFT)
  createdById   String
  createdBy     User               @relation("JournalEntryCreator", fields: [createdById], references: [id])
  approvedById  String?
  approvedBy    User?              @relation("JournalEntryApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  lines         JournalEntryLine[]
  ledgerEntries LedgerEntry[]

  @@unique([companyId, entryNumber])
  @@index([companyId])
  @@index([entryDate])
  @@index([status])
  @@index([journalId])
}

model JournalEntryLine {
  id             String         @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  description    String?
  debit          Decimal        @default(0)
  credit         Decimal        @default(0)
  createdAt      DateTime       @default(now())
  ledgerEntries  LedgerEntry[]

  @@index([journalEntryId])
}

model WarehouseZone {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  code        String
  name        String
  description String?
  isActive    Boolean   @default(true)

  bins                     WarehouseBin[]
  stockMovements           StockMovement[]
  putAwayTaskLinesFrom     PutAwayTaskLine[]         @relation("FromZone")
  putAwayTaskLinesTo       PutAwayTaskLine[]         @relation("ToZone")
  stockTransferLinesFrom   StockTransferLine[]       @relation("TransferFromZone")
  stockTransferLinesTo     StockTransferLine[]       @relation("TransferToZone")
  inventoryAdjustmentLines InventoryAdjustmentLine[]
  cycleCountLines          CycleCountLine[]
  pickingTaskLines         PickingTaskLine[]         @relation("PickingLineZone")

  @@index([warehouseId])
  @@index([code])
}

model WarehouseBin {
  id          String         @id @default(uuid())
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  zoneId      String?
  zone        WarehouseZone? @relation(fields: [zoneId], references: [id])
  code        String
  name        String
  capacity    Decimal?
  isActive    Boolean        @default(true)

  productWarehouses        ProductWarehouse[]
  stockMovements           StockMovement[]
  goodsReceiptLines        GoodsReceiptLine[]
  putAwayTaskLinesFrom     PutAwayTaskLine[]         @relation("FromBin")
  putAwayTaskLinesTo       PutAwayTaskLine[]         @relation("ToBin")
  stockTransferLinesFrom   StockTransferLine[]       @relation("TransferFromBin")
  stockTransferLinesTo     StockTransferLine[]       @relation("TransferToBin")
  inventoryAdjustmentLines InventoryAdjustmentLine[]
  cycleCountLines          CycleCountLine[]
  pickingTaskLines         PickingTaskLine[]         @relation("PickingLineBin")

  @@index([warehouseId])
  @@index([code])
}

model ProductWarehouse {
  id               String        @id @default(uuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId        String
  product          Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId      String
  warehouse        Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  binId            String?
  bin              WarehouseBin? @relation(fields: [binId], references: [id])
  quantity         Decimal       @default(0)
  reservedQuantity Decimal       @default(0)
  minimumQuantity  Decimal       @default(0)
  maximumQuantity  Decimal?
  reorderPoint     Decimal       @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
}

model StockMovement {
  id          String         @id @default(uuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId   String
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  zoneId      String?
  zone        WarehouseZone? @relation(fields: [zoneId], references: [id])
  binId       String?
  bin         WarehouseBin?  @relation(fields: [binId], references: [id])

  movementType  String
  referenceType String
  referenceId   String

  quantity      Decimal
  unitCost      Decimal?
  balanceAfter  Decimal
  remarks       String?
  performedById String?
  performedBy   Employee? @relation(fields: [performedById], references: [id])
  createdAt     DateTime  @default(now())

  batchId String?
  batch   InventoryBatch? @relation(fields: [batchId], references: [id])

  serialId                 String?
  serial                   InventorySerial?          @relation(fields: [serialId], references: [id])
  inventoryValuationLayers InventoryValuationLayer[]

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
  @@index([referenceType, referenceId])
  @@index([batchId])
  @@index([serialId])
}

model InventoryBatch {
  id                String    @id @default(uuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId       String
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batchNumber       String
  manufacturerBatch String?
  manufactureDate   DateTime?
  expiryDate        DateTime?
  receivedDate      DateTime
  quantity          Decimal
  reservedQuantity  Decimal   @default(0)
  status            String    @default("ACTIVE")
  remarks           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  stockMovements           StockMovement[]
  serials                  InventorySerial[]
  goodsReceiptLines        GoodsReceiptLine[]
  putAwayTaskLines         PutAwayTaskLine[]
  stockTransferLines       StockTransferLine[]
  inventoryAdjustmentLines InventoryAdjustmentLine[]
  cycleCountLines          CycleCountLine[]
  pickingTaskLines         PickingTaskLine[]         @relation("PickingLineBatch")

  @@unique([companyId, productId, batchNumber])
  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
  @@index([batchNumber])
  @@index([expiryDate])
}

model InventorySerial {
  id          String          @id @default(uuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batchId     String?
  batch       InventoryBatch? @relation(fields: [batchId], references: [id])

  serialNumber String
  status       String @default("AVAILABLE") // AVAILABLE, RESERVED, ALLOCATED, SOLD, RETURNED, REPAIRED, DAMAGED, SCRAPPED, LOST

  receivedDate       DateTime
  soldDate           DateTime?
  assignedCustomerId String?

  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockMovements           StockMovement[]
  goodsReceiptLines        GoodsReceiptLine[]
  putAwayTaskLines         PutAwayTaskLine[]
  stockTransferLines       StockTransferLine[]
  inventoryAdjustmentLines InventoryAdjustmentLine[]
  cycleCountLines          CycleCountLine[]
  pickingTaskLines         PickingTaskLine[]         @relation("PickingLineSerial")

  @@unique([companyId, productId, serialNumber])
  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
  @@index([serialNumber])
}

model Barcode {
  id          String  @id @default(uuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entityType  String // PRODUCT, BATCH, SERIAL, WAREHOUSE, ZONE, BIN
  entityId    String
  barcode     String? @unique
  barcodeType String? // CODE128, CODE39, EAN13, EAN8, UPC, QR
  qrCode      String? @unique
  isPrimary   Boolean @default(true)

  generatedById String?
  generatedBy   Employee? @relation(fields: [generatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([barcode])
  @@index([qrCode])
}

model GoodsReceipt {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  purchaseOrderId String?
  receiptNumber   String
  supplierId      String
  supplier        Supplier  @relation(fields: [supplierId], references: [id])
  receiptDate     DateTime  @default(now())
  status          String    @default("DRAFT") // DRAFT, RECEIVING, PARTIAL, COMPLETED, CANCELLED
  receivedById    String?
  receivedBy      Employee? @relation(fields: [receivedById], references: [id])
  remarks         String?

  lines GoodsReceiptLine[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  putAwayTasks PutAwayTask[]

  @@unique([companyId, receiptNumber])
  @@index([companyId])
  @@index([warehouseId])
  @@index([purchaseOrderId])
  @@index([supplierId])
}

model GoodsReceiptLine {
  id               String       @id @default(uuid())
  goodsReceiptId   String
  goodsReceipt     GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  productId        String
  product          Product      @relation(fields: [productId], references: [id])
  orderedQuantity  Decimal
  receivedQuantity Decimal      @default(0)
  acceptedQuantity Decimal      @default(0)
  rejectedQuantity Decimal      @default(0)

  batchId  String?
  batch    InventoryBatch?  @relation(fields: [batchId], references: [id])
  serialId String?
  serial   InventorySerial? @relation(fields: [serialId], references: [id])
  binId    String?
  bin      WarehouseBin?    @relation(fields: [binId], references: [id])

  remarks String?

  @@index([goodsReceiptId])
  @@index([productId])
}

model PutAwayTask {
  id             String        @id @default(uuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId    String
  warehouse      Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  goodsReceiptId String?
  goodsReceipt   GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id])
  taskNumber     String
  status         String        @default("PENDING") // PENDING, ASSIGNED, IN_PROGRESS, COMPLETED, CANCELLED
  assignedToId   String?
  assignedTo     Employee?     @relation(fields: [assignedToId], references: [id])
  priority       Int           @default(0)

  lines PutAwayTaskLine[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@unique([companyId, taskNumber])
  @@index([companyId])
  @@index([warehouseId])
  @@index([goodsReceiptId])
}

model PutAwayTaskLine {
  id            String      @id @default(uuid())
  putAwayTaskId String
  putAwayTask   PutAwayTask @relation(fields: [putAwayTaskId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])

  batchId  String?
  batch    InventoryBatch?  @relation(fields: [batchId], references: [id])
  serialId String?
  serial   InventorySerial? @relation(fields: [serialId], references: [id])

  fromZoneId String
  fromZone   WarehouseZone @relation("FromZone", fields: [fromZoneId], references: [id])
  fromBinId  String
  fromBin    WarehouseBin  @relation("FromBin", fields: [fromBinId], references: [id])

  toZoneId String
  toZone   WarehouseZone @relation("ToZone", fields: [toZoneId], references: [id])
  toBinId  String
  toBin    WarehouseBin  @relation("ToBin", fields: [toBinId], references: [id])

  quantity          Decimal
  completedQuantity Decimal @default(0)
  remarks           String?

  @@index([putAwayTaskId])
  @@index([productId])
}

model InventoryAdjustment {
  id               String    @id @default(uuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  adjustmentNumber String
  warehouseId      String
  warehouse        Warehouse @relation("AdjustmentWarehouse", fields: [warehouseId], references: [id])
  reason           String
  status           String    @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, POSTED, CANCELLED
  createdById      String
  createdBy        Employee  @relation("AdjustmentCreatedBy", fields: [createdById], references: [id])
  approvedById     String?
  approvedBy       Employee? @relation("AdjustmentApprovedBy", fields: [approvedById], references: [id])
  adjustmentDate   DateTime  @default(now())
  remarks          String?

  lines InventoryAdjustmentLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, adjustmentNumber])
  @@index([companyId])
  @@index([warehouseId])
}

model InventoryAdjustmentLine {
  id                    String              @id @default(uuid())
  inventoryAdjustmentId String
  inventoryAdjustment   InventoryAdjustment @relation(fields: [inventoryAdjustmentId], references: [id], onDelete: Cascade)
  productId             String
  product               Product             @relation(fields: [productId], references: [id])

  batchId  String?
  batch    InventoryBatch?  @relation(fields: [batchId], references: [id])
  serialId String?
  serial   InventorySerial? @relation(fields: [serialId], references: [id])

  warehouseId String
  warehouse   Warehouse      @relation("AdjustmentLineWarehouse", fields: [warehouseId], references: [id])
  zoneId      String?
  zone        WarehouseZone? @relation(fields: [zoneId], references: [id])
  binId       String?
  bin         WarehouseBin?  @relation(fields: [binId], references: [id])

  systemQuantity     Decimal
  physicalQuantity   Decimal
  adjustmentQuantity Decimal
  adjustmentType     String // GAIN, LOSS, DAMAGE, EXPIRED, SCRAP, FOUND, CORRECTION, WRITE_OFF
  remarks            String?

  @@index([inventoryAdjustmentId])
  @@index([productId])
  @@index([warehouseId])
}

model CycleCount {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId   String
  warehouse     Warehouse @relation("CycleCountWarehouse", fields: [warehouseId], references: [id])
  countNumber   String
  status        String    @default("PENDING") // PENDING, COUNTING, COUNTED, RECOUNT_REQUIRED, APPROVED, POSTED, CANCELLED
  scheduledDate DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  createdById   String
  createdBy     Employee  @relation("CycleCountCreatedBy", fields: [createdById], references: [id])
  approvedById  String?
  approvedBy    Employee? @relation("CycleCountApprovedBy", fields: [approvedById], references: [id])
  remarks       String?

  lines CycleCountLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, countNumber])
  @@index([companyId])
  @@index([warehouseId])
}

model CycleCountLine {
  id           String     @id @default(uuid())
  cycleCountId String
  cycleCount   CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])

  batchId  String?
  batch    InventoryBatch?  @relation(fields: [batchId], references: [id])
  serialId String?
  serial   InventorySerial? @relation(fields: [serialId], references: [id])

  warehouseId String
  warehouse   Warehouse      @relation("CycleCountLineWarehouse", fields: [warehouseId], references: [id])
  zoneId      String?
  zone        WarehouseZone? @relation(fields: [zoneId], references: [id])
  binId       String?
  bin         WarehouseBin?  @relation(fields: [binId], references: [id])

  systemQuantity  Decimal
  countedQuantity Decimal?
  variance        Decimal?
  countStatus     String   @default("PENDING") // PENDING, COUNTED, RECOUNT_REQUIRED
  remarks         String?

  @@index([cycleCountId])
  @@index([productId])
  @@index([warehouseId])
}

model InventoryValuationLayer {
  id                String         @id @default(uuid())
  companyId         String
  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId         String
  product           Product        @relation(fields: [productId], references: [id])
  warehouseId       String?
  warehouse         Warehouse?     @relation("ValuationWarehouse", fields: [warehouseId], references: [id])
  stockMovementId   String?
  stockMovement     StockMovement? @relation(fields: [stockMovementId], references: [id])
  layerType         String // RECEIPT, ADJUSTMENT_IN, INITIAL_STOCK
  quantity          Decimal
  remainingQuantity Decimal
  unitCost          Decimal
  totalCost         Decimal
  valuationMethod   String         @default("FIFO") // FIFO, LIFO, WEIGHTED_AVERAGE, SPECIFIC_ID, STANDARD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
}

model ReorderPolicy {
  id                          String    @id @default(uuid())
  companyId                   String
  company                     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId                   String
  product                     Product   @relation(fields: [productId], references: [id])
  warehouseId                 String
  warehouse                   Warehouse @relation("ReorderPolicyWarehouse", fields: [warehouseId], references: [id])
  minimumQuantity             Decimal
  maximumQuantity             Decimal
  reorderPoint                Decimal
  reorderQuantity             Decimal
  safetyStock                 Decimal
  leadTimeDays                Int
  preferredSupplierId         String?
  preferredSupplier           Supplier? @relation("PreferredSupplier", fields: [preferredSupplierId], references: [id])
  autoGeneratePurchaseRequest Boolean   @default(false)
  isActive                    Boolean   @default(true)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@unique([companyId, productId, warehouseId])
  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
}

model PurchaseRequest {
  id            String                @id @default(uuid())
  companyId     String
  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestNumber String
  warehouseId   String
  warehouse     Warehouse             @relation("PurchaseRequestWarehouse", fields: [warehouseId], references: [id])
  requestedById String
  requestedBy   Employee              @relation("PurchaseRequestedBy", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    Employee?             @relation("PurchaseRequestApprovedBy", fields: [approvedById], references: [id])
  status        String                @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, CONVERTED_TO_PO, REJECTED, CANCELLED
  requestDate   DateTime              @default(now())
  remarks       String?
  lines         PurchaseRequestLine[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([companyId, requestNumber])
  @@index([companyId])
  @@index([warehouseId])
}

model PurchaseRequestLine {
  id                  String          @id @default(uuid())
  purchaseRequestId   String
  purchaseRequest     PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  productId           String
  product             Product         @relation(fields: [productId], references: [id])
  requiredQuantity    Decimal
  recommendedQuantity Decimal
  supplierId          String?
  supplier            Supplier?       @relation("PurchaseRequestLineSupplier", fields: [supplierId], references: [id])
  estimatedUnitCost   Decimal?
  remarks             String?

  @@index([purchaseRequestId])
  @@index([productId])
}

model PickingTask {
  id           String            @id @default(uuid())
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId  String
  warehouse    Warehouse         @relation("PickingTaskWarehouse", fields: [warehouseId], references: [id])
  salesOrderId String?
  taskNumber   String
  status       String            @default("PENDING") // PENDING, ASSIGNED, IN_PROGRESS, PICKED, COMPLETED, CANCELLED
  priority     Int               @default(1)
  assignedToId String?
  assignedTo   Employee?         @relation("PickingTaskAssignedTo", fields: [assignedToId], references: [id])
  lines        PickingTaskLine[]
  packingTasks PackingTask[]
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([companyId, taskNumber])
  @@index([companyId])
  @@index([warehouseId])
}

model PickingTaskLine {
  id                String           @id @default(uuid())
  pickingTaskId     String
  pickingTask       PickingTask      @relation(fields: [pickingTaskId], references: [id], onDelete: Cascade)
  productId         String
  product           Product          @relation(fields: [productId], references: [id])
  batchId           String?
  batch             InventoryBatch?  @relation("PickingLineBatch", fields: [batchId], references: [id])
  serialId          String?
  serial            InventorySerial? @relation("PickingLineSerial", fields: [serialId], references: [id])
  zoneId            String
  zone              WarehouseZone    @relation("PickingLineZone", fields: [zoneId], references: [id])
  binId             String
  bin               WarehouseBin     @relation("PickingLineBin", fields: [binId], references: [id])
  requestedQuantity Decimal
  pickedQuantity    Decimal          @default(0)
  packedQuantity    Decimal          @default(0)
  remarks           String?

  @@index([pickingTaskId])
  @@index([productId])
  @@index([zoneId])
  @@index([binId])
}

model PackingTask {
  id            String      @id @default(uuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId   String
  warehouse     Warehouse   @relation("PackingTaskWarehouse", fields: [warehouseId], references: [id])
  pickingTaskId String
  pickingTask   PickingTask @relation(fields: [pickingTaskId], references: [id])
  packingNumber String
  status        String      @default("PENDING") // PENDING, PACKING, COMPLETED, CANCELLED
  packedById    String?
  packedBy      Employee?   @relation("PackingTaskPackedBy", fields: [packedById], references: [id])
  packedAt      DateTime?
  remarks       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([companyId, packingNumber])
  @@index([companyId])
  @@index([warehouseId])
  @@index([pickingTaskId])
}

// ==========================================
// Phase 3A Customer Master Models
// ==========================================

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model CustomerGroup {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers Customer[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Customer {
  id              String         @id @default(uuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerCode    String
  customerGroupId String?
  customerGroup   CustomerGroup? @relation(fields: [customerGroupId], references: [id])
  name            String
  displayName     String?
  email           String?
  phone           String?
  mobile          String?
  website         String?
  taxNumber       String?
  tradeLicense    String?
  creditLimit     Decimal        @default(0)
  creditDays      Int            @default(0)
  currency        String         @default("BDT")
  priceLevel      String?
  status          CustomerStatus @default(ACTIVE)
  notes           String?
  createdById     String
  createdBy       User           @relation("CustomerCreator", fields: [createdById], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  addresses CustomerAddress[]
  contacts  CustomerContact[]

  @@unique([companyId, customerCode])
  @@unique([companyId, email])
  @@unique([companyId, phone])
  @@index([companyId])
  @@index([customerGroupId])
  @@index([status])
}

model CustomerAddress {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type         String // BILLING, SHIPPING, OFFICE, WAREHOUSE
  country      String?
  state        String?
  city         String?
  postalCode   String?
  addressLine1 String
  addressLine2 String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@index([customerId])
}

model CustomerContact {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  designation String?
  email       String?
  phone       String?
  mobile      String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([customerId])
}
