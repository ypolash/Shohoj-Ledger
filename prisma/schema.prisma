  entryDate          DateTime?
  runningBalance     Decimal?
  referenceType      String?

  @@index([companyId])
  @@index([date])
  @@index([voucherNo])
  @@index([accountId])
  @@index([entryDate])
  @@index([journalEntryId])
  @@index([module])
}

model ReportAudit {
