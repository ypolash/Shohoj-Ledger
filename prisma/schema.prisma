generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  companyId               String?
  platformRole            PlatformRole?
  name                    String
  email                   String                   @unique
  emailVerified           Boolean                  @default(false)
  image                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  role                    String                   @default("member")
  sessions                Session[]
  accounts                Account[]
  payrollAudits           PayrollAudit[]
  ledgerEntries           LedgerEntry[]
  reportAudits            ReportAudit[]
  leadActivities          LeadActivity[]
  projectActivities       ProjectActivity[]
  clientActivities        ClientActivity[]
  clientDocuments         ClientDocument[]
  stockTransactions       StockTransaction[]
  inventoryAudits         InventoryAudit[]
  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  notificationAudits      NotificationAudit[]
  globalAuditLogs         GlobalAuditLog[]
  auditEvents             AuditEvent[]
  createdWorkflows        Workflow[]               @relation("WorkflowCreator")
  approvalFlows           ApprovalFlow[]           @relation("ApprovalFlowCreator")
  approvalRequests        ApprovalRequest[]        @relation("ApprovalRequester")
  approvalHistories       ApprovalHistory[]
  createdReportTemplates  ReportTemplate[]         @relation("ReportTemplateCreator")
  reportExecutions        ReportExecution[]        @relation("ReportExecutionRequester")
  notificationQueues      NotificationQueue[]
  apiKeys                 ApiKey[]                 @relation("ApiKeyCreator")
  webhooks                Webhook[]                @relation("WebhookCreator")
  managedBranches         Branch[]                 @relation("BranchManager")
  branchUsers             BranchUser[]
  createdPurchaseOrders   PurchaseOrder[]          @relation("PurchaseOrderCreator")
  createdInventoryTx      InventoryTransaction[]   @relation("InventoryTransactionCreator")
  businessInsights        BusinessInsight[]
  createdJournalEntries   JournalEntry[]           @relation("JournalEntryCreator")
  approvedJournalEntries  JournalEntry[]           @relation("JournalEntryApprover")
  createdCustomers        Customer[]               @relation("CustomerCreator")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model Project {
  id              String     @id @default(uuid())
  companyId       String?
  company         Company?   @relation(fields: [companyId], references: [id])
  projectCode     String?
  name            String
  description     String?
  category        String?
  priority        String?    @default("Medium")
  status          String     @default("Draft")
  progress        Int?       @default(0)
  clientName      String?
  clientId        String?
  client          Client?    @relation(fields: [clientId], references: [id])
  leadId          String?
  lead            Lead?      @relation(fields: [leadId], references: [id])
  managerId       String?
  manager         Employee?  @relation("ProjectManager", fields: [managerId], references: [id])
  teamMembers     Employee[] @relation("ProjectTeam")
  startDate       DateTime?
  endDate         DateTime?
  estimatedBudget Decimal?
  actualCost      Decimal?   @default(0)
  tags            String[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tasks      Task[]
  activities ProjectActivity[]

  @@unique([companyId, projectCode])
  @@index([companyId])
}

model Income {
  id            String   @id @default(uuid())
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id])
  projectId     String?
  category      String
  source        String?
  amount        Decimal
  received      Decimal  @default(0)
  paymentStatus String
  shareable     Boolean  @default(true)
  description   String?
  createdAt     DateTime @default(now())

  @@index([companyId])
}

model Expense {
  id             String   @id @default(uuid())
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  projectId      String?
  category       String
  amount         Decimal
  paymentMethod  String
  approvalStatus String
  description    String?
  createdAt      DateTime @default(now())

  @@index([companyId])
}

model FundTransaction {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  amount      Decimal
  source      String?
  description String?
  createdAt   DateTime @default(now())

  @@index([companyId])
}

model ReserveTransaction {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  type      String
  amount    Decimal
  reason    String?
  createdAt DateTime @default(now())

  @@index([companyId])
}

model MemberLoan {
  id              String   @id @default(uuid())
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])
  memberId        String
  amount          Decimal
  remainingAmount Decimal
  reason          String?
  issueDate       DateTime @default(now())
  dueDate         DateTime
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())

  @@index([companyId])
}

model Advance {
  id              String   @id @default(uuid())
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])
  memberId        String
  amount          Decimal
  remainingAmount Decimal
  reason          String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())

  @@index([companyId])
}

model Settlement {
  id             String   @id @default(uuid())
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  period         String
  status         String   @default("PENDING")
  totalIncome    Decimal
  totalExpenses  Decimal
  ceoShare       Decimal
  developerShare Decimal
  advisorShare   Decimal
  companyShare   Decimal
  createdAt      DateTime @default(now())

  @@index([companyId])
}

model IncomeCategory {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String   @unique
  createdAt DateTime @default(now())

  @@index([companyId])
}

model Member {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String
  role      String
  email     String?  @unique
  phone     String?
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Employee {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  userId      String?  @unique // Link to User model if they can log in
  employeeId  String   @unique
  password    String?
  firstName   String
  lastName    String
  email       String   @unique
  phone       String?
  designation String
  department  String?
  joinDate    DateTime
  basicSalary Decimal
  status      String   @default("ACTIVE") // ACTIVE, ON_LEAVE, TERMINATED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendances    Attendance[]
  leaveRequests  LeaveRequest[]
  salaryPayments SalaryPayment[]
  deductions     SalaryDeduction[]
  bonuses        Bonus[]
  payslips       Payslip[]
  tasks          Task[]

  departmentId  String?
  departmentRef Department? @relation("EmployeeDepartment", fields: [departmentId], references: [id])

  designationId  String?
  designationRef Designation? @relation("EmployeeDesignation", fields: [designationId], references: [id])

  reportingManagerId String?
  reportingManager   Employee?  @relation("EmployeeToManager", fields: [reportingManagerId], references: [id])
  subordinates       Employee[] @relation("EmployeeToManager")

  headOfDepartment Department[] @relation("DepartmentHead")

  employmentType   String?
  location         String?
  shift            String?
  employmentStatus String? @default("Probation")

  lifecycleEvents              EmployeeLifecycle[]
  leads                        Lead[]
  managedProjects              Project[]             @relation("ProjectManager")
  teamProjects                 Project[]             @relation("ProjectTeam")
  managedWarehouses            Warehouse[]           @relation("WarehouseManager")
  assignedAssets               Asset[]               @relation("EmployeeAssets")
  stockMovements               StockMovement[]
  barcodes                     Barcode[]
  goodsReceipts                GoodsReceipt[]
  putAwayTasks                 PutAwayTask[]
  transfersRequested           StockTransfer[]       @relation("TransferRequestedBy")
  transfersApproved            StockTransfer[]       @relation("TransferApprovedBy")
  inventoryAdjustmentsCreated  InventoryAdjustment[] @relation("AdjustmentCreatedBy")
  inventoryAdjustmentsApproved InventoryAdjustment[] @relation("AdjustmentApprovedBy")
  cycleCountsCreated           CycleCount[]          @relation("CycleCountCreatedBy")
  cycleCountsApproved          CycleCount[]          @relation("CycleCountApprovedBy")
  purchaseRequestsRequested    PurchaseRequest[]     @relation("PurchaseRequestedBy")
  purchaseRequestsApproved     PurchaseRequest[]     @relation("PurchaseRequestApprovedBy")
  pickingTasksAssigned         PickingTask[]         @relation("PickingTaskAssignedTo")
  packingTasksPacked           PackingTask[]         @relation("PackingTaskPackedBy")

  @@index([companyId])
}

model Task {
  id                   String    @id @default(uuid())
  companyId            String?
  company              Company?  @relation(fields: [companyId], references: [id])
  projectId            String?
  project              Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedToEmployeeId String?
  employee             Employee? @relation(fields: [assignedToEmployeeId], references: [employeeId])
  title                String
  description          String?
  priority             String?   @default("Medium")
  status               String    @default("To Do") // To Do, In Progress, Review, Testing, Completed
  dueDate              DateTime?
  estimatedHours       Decimal?  @default(0)
  actualHours          Decimal?  @default(0)
  checklist            Json?
  attachments          Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([companyId])
  @@index([projectId])
}

model Attendance {
  id                  String    @id @default(uuid())
  companyId           String?
  company             Company?  @relation(fields: [companyId], references: [id])
  employeeId          String
  employee            Employee  @relation(fields: [employeeId], references: [id])
  date                DateTime // Store just the date (YYYY-MM-DD)
  checkInTime         DateTime? @map("checkIn")
  checkInLocation     String?
  checkOutTime        DateTime? @map("checkOut")
  checkOutLocation    String?
  status              String // PRESENT, LATE, ABSENT, HALF_DAY, WEEKLY_OFF, OFF_DAY_WORK
  isLate              Boolean   @default(false)
  lateMinutes         Int       @default(0)
  totalWorkingMinutes Int?      @default(0)
  earlyLeaveMinutes   Int?      @default(0)
  overtimeMinutes     Int?      @default(0)
  punishmentReason    String?
  reviewStatus        String?
  punishmentAmount    Decimal?  @default(0)
  latitude            Float?
  longitude           Float?
  wifiSsid            String?
  wifiBssid           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([employeeId, date])
  @@index([companyId])
}

model LeaveRequest {
  id         String   @id @default(uuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String // CASUAL, SICK, UNPAID
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
}

model SalaryPayment {
  id             String    @id @default(uuid())
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id])
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id])
  month          Int // 1-12
  year           Int
  basicSalary    Decimal
  grossSalary    Decimal
  netSalary      Decimal
  paymentDate    DateTime?
  status         String    @default("PAID") // DRAFT, CALCULATED, SUBMITTED, APPROVED, PAID, LOCKED, ARCHIVED
  expenseId      String? // Link to Expense model record in Shohoj Ledger
  paymentMethod  String?
  transactionRef String?
  paymentNote    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  audits PayrollAudit[]

  @@index([companyId])
}

model SalaryDeduction {
  id         String   @id @default(uuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  month      Int
  year       Int
  type       String // LATE_FEE, UNPAID_LEAVE, OTHER
  amount     Decimal
  reason     String?
  createdAt  DateTime @default(now())

  @@index([companyId])
}

model Bonus {
  id         String   @id @default(uuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  month      Int
  year       Int
  type       String // PERFORMANCE, FESTIVAL, OTHER
  amount     Decimal
  reason     String?
  expenseId  String? // Link to Expense model record
  createdAt  DateTime @default(now())

  @@index([companyId])
}

model Payslip {
  id              String   @id @default(uuid())
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  month           Int
  year            Int
  fileUrl         String? // If storing PDF generated
  totalEarnings   Decimal
  totalDeductions Decimal
  netPay          Decimal
  createdAt       DateTime @default(now())

  @@unique([employeeId, month, year])
  @@index([companyId])
}

model Lead {
  id                  String         @id @default(uuid())
  companyId           String?
  company             Company?       @relation(fields: [companyId], references: [id])
  serialNumber        Int            @default(autoincrement())
  companyName         String
  clientId            String?
  client              Client?        @relation(fields: [clientId], references: [id])
  contactPerson       String
  phone               String
  email               String?
  serviceType         String
  expectedValue       Decimal
  leadSource          String?
  assignedToId        String?
  assignedTo          Employee?      @relation(fields: [assignedToId], references: [id])
  nextFollowUp        DateTime?
  notes               String?
  status              String         @default("New")
  priority            String         @default("Medium")
  lostReason          String?
  website             String?
  address             String?
  industry            String?
  expectedClosingDate DateTime?
  tags                String[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  activities          LeadActivity[]
  projects            Project[]

  @@index([status])
  @@index([serviceType])
  @@index([nextFollowUp])
  @@index([assignedToId])
  @@index([companyId])
}

model LeadActivity {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type          String // CREATED, UPDATED, STATUS_CHANGE, ASSIGNED, FOLLOW_UP_CALL, FOLLOW_UP_MEETING, FOLLOW_UP_EMAIL, FOLLOW_UP_WHATSAPP, FOLLOW_UP_TASK, FOLLOW_UP_REMINDER
  description   String?
  oldValue      String?
  newValue      String?
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([companyId])
  @@index([leadId])
}

model AllowedNetwork {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String
  ssid      String
  bssid     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model PunishmentSetting {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  type        String // LATE, EARLY_LEAVE, ABSENT
  fromMinutes Int
  toMinutes   Int
  amount      Decimal
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

model AttendanceConfig {
  id                        String   @id @default(uuid())
  companyId                 String?
  company                   Company? @relation(fields: [companyId], references: [id])
  gracePeriod               Int      @default(15)
  shiftStart                String   @default("09:00") // HH:mm
  shiftEnd                  String   @default("20:00") // HH:mm
  fridayOff                 Boolean  @default(true)
  enablePunishmentDeduction Boolean  @default(false)

  @@index([companyId])
}

enum WorkflowStepType {
  ACTION
  CONDITION
  NOTIFICATION
  TASK
}

enum WebhookStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  RECEIVED
  CANCELLED
}

enum InventoryTransactionType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum StockTransferStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum InsightType {
  REVENUE
  EXPENSE
  ATTENDANCE
  PAYROLL
  INVENTORY
  CUSTOM
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

enum ReportFormat {
  PDF
  EXCEL
  CSV
}

enum ReportExecutionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ReportPermissionType {
  VIEW
  EXPORT
  MANAGE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalAction {
  SUBMITTED
  APPROVED
  REJECTED
  FORWARDED
  CANCELLED
}

enum ApproverType {
  ROLE
  USER
  MANAGER
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  APPROVAL
  EXPORT
}

enum NotificationType {
  SYSTEM
  TASK
  APPROVAL
  PAYROLL
  SECURITY
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum BusinessType {
  PRODUCT
  SERVICE
  BOTH
}

enum CompanyStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum PlatformRole {
  SUPER_ADMIN
  USER
}

model Company {
  id                       String                    @id @default(uuid())
  name                     String
  businessType             String
  status                   String                    @default("ACTIVE")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  settings                 CompanySetting?
  modules                  CompanyModule[]
  roles                    Role[]
  projects                 Project[]
  incomes                  Income[]
  expenses                 Expense[]
  fundTransactions         FundTransaction[]
  reserveTransactions      ReserveTransaction[]
  memberLoans              MemberLoan[]
  advances                 Advance[]
  settlements              Settlement[]
  incomeCategories         IncomeCategory[]
  members                  Member[]
  employees                Employee[]
  tasks                    Task[]
  attendances              Attendance[]
  leaveRequests            LeaveRequest[]
  salaryPayments           SalaryPayment[]
  salaryDeductions         SalaryDeduction[]
  bonuses                  Bonus[]
  payslips                 Payslip[]
  leads                    Lead[]
  allowedNetworks          AllowedNetwork[]
  punishmentSettings       PunishmentSetting[]
  attendanceConfigs        AttendanceConfig[]
  departments              Department[]
  designations             Designation[]
  lifecycles               EmployeeLifecycle[]
  payrollAudits            PayrollAudit[]
  ledgerEntries            LedgerEntry[]
  reportAudits             ReportAudit[]
  leadActivities           LeadActivity[]
  projectActivities        ProjectActivity[]
  clients                  Client[]
  productCategories        ProductCategory[]
  products                 Product[]
  warehouses               Warehouse[]
  suppliers                Supplier[]
  purchaseOrders           PurchaseOrder[]
  stockTransactions        StockTransaction[]
  assetCategories          AssetCategory[]
  assets                   Asset[]
  inventoryAudits          InventoryAudit[]
  notificationPreferences  NotificationPreference[]
  notificationTemplates    NotificationTemplate[]
  notifications            Notification[]
  announcements            Announcement[]
  notificationAudits       NotificationAudit[]
  globalAuditLogs          GlobalAuditLog[]
  auditEvents              AuditEvent[]
  backgroundJobs           BackgroundJob[]
  workflows                Workflow[]
  workflowExecutions       WorkflowExecution[]
  analyticsSnapshots       AnalyticsSnapshot[]
  businessInsights         BusinessInsight[]
  forecastRecords          ForecastRecord[]
  approvalFlows            ApprovalFlow[]
  approvalSteps            ApprovalStep[]
  approvalRequests         ApprovalRequest[]
  approvalHistories        ApprovalHistory[]
  reportTemplates          ReportTemplate[]
  reportExecutions         ReportExecution[]
  scheduledReports         ScheduledReport[]
  notificationQueues       NotificationQueue[]
  notificationDeliveryLogs NotificationDeliveryLog[]
  apiKeys                  ApiKey[]
  webhooks                 Webhook[]
  webhookDeliveries        WebhookDelivery[]
  branches                 Branch[]
  inventoryTransactions    InventoryTransaction[]
  stockTransfers           StockTransfer[]

  // Phase 1A Accounting Foundation
  chartOfAccounts          ChartOfAccount[]
  fiscalYears              FiscalYear[]
  accountingPeriods        AccountingPeriod[]
  journals                 Journal[]
  journalEntries           JournalEntry[]
  productWarehouses        ProductWarehouse[]
  stockMovements           StockMovement[]
  inventoryBatches         InventoryBatch[]
  inventorySerials         InventorySerial[]
  barcodes                 Barcode[]
  goodsReceipts            GoodsReceipt[]
  putAwayTasks             PutAwayTask[]
  inventoryAdjustments     InventoryAdjustment[]
  cycleCounts              CycleCount[]
  inventoryValuationLayers InventoryValuationLayer[]
  reorderPolicies          ReorderPolicy[]
  purchaseRequests         PurchaseRequest[]
  pickingTasks             PickingTask[]
  packingTasks             PackingTask[]

  // Phase 3A Customer Master
  customerGroups    CustomerGroup[]
  customers         Customer[]
  customerAddresses CustomerAddress[]
  customerContacts  CustomerContact[]
}

model CompanySetting {
  id                 String  @id @default(uuid())
  companyId          String  @unique
  company            Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currency           String  @default("BDT")
  timezone           String  @default("Asia/Dhaka")
  workingDays        Json
  weeklyHolidays     Json
  shiftStartTime     String
  shiftEndTime       String
  gracePeriodMinutes Int
}

model Module {
  id                String             @id @default(uuid())
  key               String             @unique
  name              String
  description       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  companies         CompanyModule[]
  modulePermissions ModulePermission[]
}

model CompanyModule {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  moduleId  String
  module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  isActive  Boolean @default(true)

  @@unique([companyId, moduleId])
}

model Role {
  id                String             @id @default(uuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name              String
  isDefault         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  permissions       RolePermission[]
  reportPermissions ReportPermission[]
  branchPermissions BranchPermission[]
}

model Permission {
  id                String             @id @default(uuid())
  action            String             @unique
  moduleKey         String
  roles             RolePermission[]
  modulePermissions ModulePermission[]
  branchPermissions BranchPermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Department {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
