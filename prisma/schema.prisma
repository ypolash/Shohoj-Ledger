  voucherNo   String
  voucherType String

  referenceId String?
  module      String

  accountType String
  debit       Decimal @default(0)
  credit      Decimal @default(0)

  status      String  @default("COMPLETED")
  description String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

