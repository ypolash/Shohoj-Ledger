  inventoryAdjustmentLines InventoryAdjustmentLine[] @relation("AdjustmentLineWarehouse")
  cycleCounts              CycleCount[]              @relation("CycleCountWarehouse")
  cycleCountLines          CycleCountLine[]          @relation("CycleCountLineWarehouse")
  valuationLayers          InventoryValuationLayer[] @relation("ValuationWarehouse")
  reorderPolicies          ReorderPolicy[]           @relation("ReorderPolicyWarehouse")
  purchaseRequisitionLines PurchaseRequisitionLine[] @relation("PurchaseRequisitionWarehouse")
  pickingTasks             PickingTask[]             @relation("PickingTaskWarehouse")
  packingTasks             PackingTask[]             @relation("PackingTaskWarehouse")
  quotationLines           QuotationLine[]           @relation("QuotationLineWarehouse")
  salesOrderLines          SalesOrderLine[]          @relation("SalesOrderLineWarehouse")
  deliveryOrders           DeliveryOrder[]           @relation("DeliveryOrderWarehouse")
  deliveryOrderLines       DeliveryOrderLine[]       @relation("DeliveryOrderLineWarehouse")
  customerReturns          CustomerReturn[]          @relation("CustomerReturnWarehouse")
  customerReturnLines      CustomerReturnLine[]      @relation("CustomerReturnLineWarehouse")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([code])
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  BLACKLISTED
}

model SupplierCategory {
  id          String     @id @default(uuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  suppliers   Supplier[]

  @@unique([companyId, name])
}

model Supplier {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  supplierCode String
  name         String
  taxNumber    String?
  vatNumber    String?
  tradeLicense String?

  paymentTerms String?
  creditLimit  Decimal @default(0)
  currency     String  @default("USD")

  status SupplierStatus @default(ACTIVE)

  // Future Supplier Portal Auth
  portalPassword String?
  isPortalActive Boolean @default(false)

  // Legacy fields (kept for backward compatibility with early phases if needed, though they will be replaced by relations)
  contactPerson      String?
  email              String?
  phone              String?
  address            String?
  outstandingBalance Decimal @default(0)
  isActive           Boolean @default(true)

  createdById String?
  createdBy   User?   @relation("SupplierCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String?
  category   SupplierCategory? @relation(fields: [categoryId], references: [id])

  addresses      SupplierAddress[]
  contacts       SupplierContact[]
  bankAccounts   SupplierBankAccount[]
  documents      SupplierDocument[]
  communications SupplierCommunicationLog[]

  purchaseOrders  PurchaseOrder[]
  reorderPolicies ReorderPolicy[] @relation("PreferredSupplier")

  goodsReceiptNotes GoodsReceiptNote[]
  supplierInvoices  SupplierInvoice[]
  supplierPayments  SupplierPayment[]
  vendorQuotations  VendorQuotation[]
  vendorComparisons VendorComparisonItem[]

  @@unique([companyId, supplierCode])
  @@index([companyId])
  @@index([categoryId])
  @@index([status])
}

model SupplierAddress {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type        String   @default("BILLING") // BILLING, SHIPPING, WAREHOUSE
  addressLine String
  city        String?
  state       String?
  zipCode     String?
  country     String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplierId])
}

model SupplierContact {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name        String
  designation String?
  email       String?
  phone       String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplierId])
}

model SupplierBankAccount {
  id            String   @id @default(uuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  bankName      String
  accountName   String
  accountNumber String
  routingNumber String?
  swiftCode     String?
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([supplierId])
}

model SupplierDocument {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  title      String
  fileUrl    String
  type       String // e.g. NDA, CONTRACT, TAX_FORM
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([supplierId])
}

model SupplierCommunicationLog {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type       String // EMAIL, CALL, MEETING
  notes      String
  date       DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([supplierId])
}

model PurchaseOrder {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  purchaseOrderNumber String

  vendorComparisonId String?
  // We can loosely couple vendor comparison since it wasn't strictly asked to be a relation, 
  // but let's add relation just in case it's needed for consistency? No, user explicitly defined `vendorComparisonId String?`

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  // Kept for backward compatibility with existing views if necessary, though user spec says to put warehouseId on Line level.
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  status PurchaseOrderStatus @default(DRAFT)

  orderDate            DateTime  @default(now())
  expectedDeliveryDate DateTime?

  currency String @default("USD")

  subtotal       Decimal @default(0)
  discountAmount Decimal @default(0)
  taxAmount      Decimal @default(0)
  shippingAmount Decimal @default(0)
  totalAmount    Decimal @default(0)

  paymentTerms String?
  remarks      String?

  approvedById String?
  approvedBy   User?     @relation("PurchaseOrderApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  createdById String?
  createdBy   User?   @relation("PurchaseOrderCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines             PurchaseOrderLine[]
  goodsReceiptNotes GoodsReceiptNote[]
  supplierInvoices  SupplierInvoice[]
  threeWayMatches   ThreeWayMatch[]
  stockTransactions StockTransaction[]

  @@unique([companyId, purchaseOrderNumber])
  @@index([companyId])
  @@index([status])
  @@index([supplierId])
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  warehouseId String?

  quantity         Decimal
  receivedQuantity Decimal @default(0)

  unitPrice       Decimal
  discountPercent Decimal @default(0)
  discountAmount  Decimal @default(0)
  taxPercent      Decimal @default(0)
  taxAmount       Decimal @default(0)
  lineTotal       Decimal

  remarks String?

  goodsReceiptLines    GoodsReceiptLine[]
  supplierInvoiceLines SupplierInvoiceLine[]

  @@index([purchaseOrderId])
  @@index([productId])
}

enum SupplierInvoiceStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  POSTED
  REJECTED
  CANCELLED
}

enum ThreeWayMatchStatus {
  MATCHED
  QUANTITY_MISMATCH
  PRICE_MISMATCH
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model SupplierInvoice {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invoiceNumber String

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  goodsReceiptNoteId String?
  goodsReceiptNote   GoodsReceiptNote? @relation(fields: [goodsReceiptNoteId], references: [id])

  invoiceDate DateTime
  dueDate     DateTime?

  currency String @default("USD")

  subtotal       Decimal @default(0)
  discountAmount Decimal @default(0)
  taxAmount      Decimal @default(0)
  shippingAmount Decimal @default(0)
  totalAmount    Decimal @default(0)

  status  SupplierInvoiceStatus @default(DRAFT)
  remarks String?

  approvedById String?
  approvedBy   User?     @relation("SupplierInvoiceApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  createdById String?
  createdBy   User?   @relation("SupplierInvoiceCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines                      SupplierInvoiceLine[]
  threeWayMatches            ThreeWayMatch[]
  supplierPaymentAllocations SupplierPaymentAllocation[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([goodsReceiptNoteId])
  @@index([status])
}

model SupplierInvoiceLine {
  id String @id @default(uuid())

  supplierInvoiceId String
  supplierInvoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  purchaseOrderLineId String?
  purchaseOrderLine   PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])

  goodsReceiptLineId String?
  goodsReceiptLine   GoodsReceiptLine? @relation(fields: [goodsReceiptLineId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  quantity       Decimal
  unitPrice      Decimal
  discountAmount Decimal @default(0)
  taxAmount      Decimal @default(0)
  lineTotal      Decimal

  @@index([supplierInvoiceId])
  @@index([purchaseOrderLineId])
  @@index([goodsReceiptLineId])
  @@index([productId])
}

model ThreeWayMatch {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  goodsReceiptNoteId String
  goodsReceiptNote   GoodsReceiptNote @relation(fields: [goodsReceiptNoteId], references: [id])

  supplierInvoiceId String
  supplierInvoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id])

  matchStatus ThreeWayMatchStatus @default(PENDING_REVIEW)

  quantityMatched Boolean @default(false)
  priceMatched    Boolean @default(false)
  varianceAmount  Decimal @default(0)

  remarks String?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([purchaseOrderId])
  @@index([goodsReceiptNoteId])
  @@index([supplierInvoiceId])
  @@index([matchStatus])
}

enum SupplierPaymentStatus {
  DRAFT
  PENDING
  POSTED
  PARTIALLY_ALLOCATED
  FULLY_ALLOCATED
  CANCELLED
}

model SupplierPayment {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  paymentNumber String

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  paymentDate     DateTime
  paymentMethod   PaymentMethod @default(BANK)
  referenceNumber String?

  bankAccountId String?

  currency String @default("USD")

  amount            Decimal @default(0)
  allocatedAmount   Decimal @default(0)
  unallocatedAmount Decimal @default(0)

  status  SupplierPaymentStatus @default(DRAFT)
  remarks String?

  createdById String?
  createdBy   User?   @relation("SupplierPaymentCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  allocations SupplierPaymentAllocation[]

  @@unique([companyId, paymentNumber])
  @@index([companyId])
  @@index([supplierId])
  @@index([status])
}

model SupplierPaymentAllocation {
  id String @id @default(uuid())

  supplierPaymentId String
  supplierPayment   SupplierPayment @relation(fields: [supplierPaymentId], references: [id], onDelete: Cascade)

  supplierInvoiceId String
  supplierInvoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  allocatedAmount Decimal

  createdAt DateTime @default(now())

  @@index([supplierPaymentId])
  @@index([supplierInvoiceId])
}

model StockTransaction {
  id              String         @id @default(uuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId     String
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  type            String
  quantity        Int
  reference       String?
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  notes           String?
  createdAt       DateTime       @default(now())
  performedById   String
  performedBy     User           @relation(fields: [performedById], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
}

model AssetCategory {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Asset {
  id               String        @id @default(uuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assetCode        String
  name             String
  categoryId       String
  category         AssetCategory @relation(fields: [categoryId], references: [id])
  purchaseDate     DateTime?
  purchasePrice    Decimal       @default(0)
  warrantyExpDate  DateTime?
  serialNumber     String?
  currentLocation  String?
  depreciationRate Decimal       @default(0)
  status           String        @default("ACTIVE")
  assignedToId     String?
  assignedTo       Employee?     @relation("EmployeeAssets", fields: [assignedToId], references: [id])
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([companyId, assetCode])
  @@index([companyId])
}

model InventoryAudit {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  action        String
  entityType    String
  entityId      String
  description   String?
  oldValue      String?
  newValue      String?
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([companyId])
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  category  String // e.g., "HR", "PAYROLL", "SYSTEM"
  subject   String
  body      String // Supports variables like {{EmployeeName}}
  channels  String[] // e.g., ["EMAIL", "IN_APP"]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queues NotificationQueue[]

  @@unique([companyId, name])
  @@index([companyId])
}

model NotificationPreference {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled      Boolean  @default(true)
  inAppEnabled      Boolean  @default(true)
  smsEnabled        Boolean  @default(false)
  pushEnabled       Boolean  @default(false)
  mutedCategories   String[] // e.g., ["CRM", "INVENTORY"]
  digestMode        Boolean  @default(false)
  workingHoursStart String? // e.g., "09:00"
  workingHoursEnd   String? // e.g., "18:00"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([companyId, userId])
  @@index([companyId])
}

model NotificationQueue {
  id           String               @id @default(uuid())
  companyId    String
  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId   String
  template     NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  channel      NotificationChannel
  payload      Json?
  status       NotificationStatus   @default(PENDING)
  scheduledAt  DateTime?
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime             @default(now())

  deliveryLogs NotificationDeliveryLog[]

  @@index([companyId])
  @@index([status])
  @@index([scheduledAt])
}

model NotificationDeliveryLog {
  id               String              @id @default(uuid())
  companyId        String
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  notificationId   String
  notification     NotificationQueue   @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel          NotificationChannel
  status           NotificationStatus
  providerResponse Json?
  deliveredAt      DateTime?
  createdAt        DateTime            @default(now())

  @@index([companyId])
  @@index([createdAt])
}

model Notification {
  id        String            @id @default(uuid())
  companyId String
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String // e.g., "SYSTEM", "HR", "PAYROLL", "PROJECTS"
  title     String
  message   String
  link      String?
  channel   String            @default("IN_APP")
  status    String            @default("UNREAD") // UNREAD, READ, ARCHIVED
  priority  String            @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  isPinned  Boolean           @default(false)
  type      NotificationType?
  read      Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([companyId, userId, status])
  @@index([companyId])
}

model Announcement {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title      String
  message    String
  targetType String // EVERYONE, DEPARTMENT, ROLE, EMPLOYEE
  targetId   String? // ID of the specific target
  priority   String   @default("NORMAL")
  status     String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
}

model NotificationAudit {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  action        String // SENT, READ, DELETED, TEMPLATE_UPDATED
  entityType    String // NOTIFICATION, ANNOUNCEMENT, TEMPLATE
  entityId      String
  description   String?
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([companyId])
}

model GlobalAuditLog {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  module      String // HR, PAYROLL, INVENTORY, SYSTEM, CRM, etc.
  entityType  String // Employee, Project, etc.
  entityId    String
  action      String // CREATE, UPDATE, DELETE, LOGIN, EXPORT
  description String?
  beforeValue String? // JSON stringified
  afterValue  String? // JSON stringified
  ipAddress   String?
  userAgent   String?
  status      String   @default("SUCCESS") // SUCCESS, FAILED
  createdAt   DateTime @default(now())

  @@index([companyId, module])
  @@index([companyId, userId])
  @@index([companyId, entityType, entityId])
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String // JSON stringified for arrays/objects
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeatureFlag {
  id                String   @id @default(uuid())
  key               String   @unique
  description       String?
  isEnabled         Boolean  @default(false)
  rolloutPercentage Int      @default(100) // 0-100
  enabledCompanyIds String[] // Array of company IDs that have this enabled (bypasses rollout if present)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SystemBackup {
  id          String    @id @default(uuid())
  fileName    String
  fileSize    BigInt?
  status      String    @default("PENDING") // PENDING, SUCCESS, FAILED
  triggeredBy String? // User ID who triggered it, or System
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

model AuditEvent {
  id        String      @id @default(uuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    AuditAction
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
}

model ModulePermission {
  id           String     @id @default(uuid())
  moduleId     String
  module       Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([moduleId, permissionId])
}

model BackgroundJob {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String
  status      JobStatus @default(PENDING)
  payload     Json?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([companyId])
  @@index([createdAt])
}

model Workflow {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  moduleKey   String
  isActive    Boolean  @default(true)
  createdById String
  createdBy   User     @relation("WorkflowCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps      WorkflowStep[]
  triggers   WorkflowTrigger[]
  executions WorkflowExecution[]

  @@index([companyId])
  @@index([moduleKey])
}

model WorkflowStep {
  id         String           @id @default(uuid())
  workflowId String
  workflow   Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepOrder  Int
  type       WorkflowStepType
  config     Json?
  createdAt  DateTime         @default(now())
}

model WorkflowTrigger {
