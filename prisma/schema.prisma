  metricValue Decimal?
  metadata    Json?
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([metricKey])
  @@index([periodStart])
}

model BusinessInsight {
