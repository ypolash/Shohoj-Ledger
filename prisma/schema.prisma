  warehouseZone WarehouseZone? @relation(fields: [zoneId], references: [id])

  binId String?
  bin   WarehouseBin? @relation(fields: [binId], references: [id])

  remarks              String?
  supplierInvoiceLines SupplierInvoiceLine[]

  @@index([goodsReceiptNoteId])
  @@index([purchaseOrderLineId])
  @@index([productId])
}

model PutAwayTask {
  id                 String            @id @default(uuid())
  companyId          String
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId        String
  warehouse          Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  goodsReceiptNoteId String?
  goodsReceiptNote   GoodsReceiptNote? @relation(fields: [goodsReceiptNoteId], references: [id])
  taskNumber         String
  status             String            @default("PENDING") // PENDING, ASSIGNED, IN_PROGRESS, COMPLETED, CANCELLED
  assignedToId       String?
  assignedTo         Employee?         @relation(fields: [assignedToId], references: [id])
  priority           Int               @default(0)

  lines PutAwayTaskLine[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@unique([companyId, taskNumber])
  @@index([companyId])
  @@index([warehouseId])
  @@index([goodsReceiptNoteId])
}

model PutAwayTaskLine {
  id            String      @id @default(uuid())
  putAwayTaskId String
  putAwayTask   PutAwayTask @relation(fields: [putAwayTaskId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])

  batchId  String?
  batch    InventoryBatch?  @relation(fields: [batchId], references: [id])
  serialId String?
  serial   InventorySerial? @relation(fields: [serialId], references: [id])

  fromZoneId String
  fromZone   WarehouseZone @relation("FromZone", fields: [fromZoneId], references: [id])
  fromBinId  String
  fromBin    WarehouseBin  @relation("FromBin", fields: [fromBinId], references: [id])

  toZoneId String
  toZone   WarehouseZone @relation("ToZone", fields: [toZoneId], references: [id])
  toBinId  String
  toBin    WarehouseBin  @relation("ToBin", fields: [toBinId], references: [id])

  quantity          Decimal
  completedQuantity Decimal @default(0)
  remarks           String?

  @@index([putAwayTaskId])
  @@index([productId])
}

model InventoryAdjustment {
  id               String    @id @default(uuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  adjustmentNumber String
  warehouseId      String
  warehouse        Warehouse @relation("AdjustmentWarehouse", fields: [warehouseId], references: [id])
  reason           String
  status           String    @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, POSTED, CANCELLED
  createdById      String
  createdBy        Employee  @relation("AdjustmentCreatedBy", fields: [createdById], references: [id])
  approvedById     String?
  approvedBy       Employee? @relation("AdjustmentApprovedBy", fields: [approvedById], references: [id])
  adjustmentDate   DateTime  @default(now())
  remarks          String?

  lines InventoryAdjustmentLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, adjustmentNumber])
  @@index([companyId])
  @@index([warehouseId])
}

model InventoryAdjustmentLine {
  id                    String              @id @default(uuid())
  inventoryAdjustmentId String
  inventoryAdjustment   InventoryAdjustment @relation(fields: [inventoryAdjustmentId], references: [id], onDelete: Cascade)
  productId             String
  product               Product             @relation(fields: [productId], references: [id])

  batchId  String?
  batch    InventoryBatch?  @relation(fields: [batchId], references: [id])
  serialId String?
  serial   InventorySerial? @relation(fields: [serialId], references: [id])

  warehouseId String
  warehouse   Warehouse      @relation("AdjustmentLineWarehouse", fields: [warehouseId], references: [id])
  zoneId      String?
  zone        WarehouseZone? @relation(fields: [zoneId], references: [id])
  binId       String?
  bin         WarehouseBin?  @relation(fields: [binId], references: [id])

  systemQuantity     Decimal
  physicalQuantity   Decimal
  adjustmentQuantity Decimal
  adjustmentType     String // GAIN, LOSS, DAMAGE, EXPIRED, SCRAP, FOUND, CORRECTION, WRITE_OFF
  remarks            String?

  @@index([inventoryAdjustmentId])
  @@index([productId])
  @@index([warehouseId])
}

model CycleCount {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId   String
  warehouse     Warehouse @relation("CycleCountWarehouse", fields: [warehouseId], references: [id])
  countNumber   String
  status        String    @default("PENDING") // PENDING, COUNTING, COUNTED, RECOUNT_REQUIRED, APPROVED, POSTED, CANCELLED
  scheduledDate DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  createdById   String
  createdBy     Employee  @relation("CycleCountCreatedBy", fields: [createdById], references: [id])
  approvedById  String?
  approvedBy    Employee? @relation("CycleCountApprovedBy", fields: [approvedById], references: [id])
  remarks       String?

  lines CycleCountLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, countNumber])
  @@index([companyId])
  @@index([warehouseId])
}

model CycleCountLine {
  id           String     @id @default(uuid())
  cycleCountId String
  cycleCount   CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])

  batchId  String?
  batch    InventoryBatch?  @relation(fields: [batchId], references: [id])
  serialId String?
  serial   InventorySerial? @relation(fields: [serialId], references: [id])

  warehouseId String
  warehouse   Warehouse      @relation("CycleCountLineWarehouse", fields: [warehouseId], references: [id])
  zoneId      String?
  zone        WarehouseZone? @relation(fields: [zoneId], references: [id])
  binId       String?
  bin         WarehouseBin?  @relation(fields: [binId], references: [id])

  systemQuantity  Decimal
  countedQuantity Decimal?
  variance        Decimal?
  countStatus     String   @default("PENDING") // PENDING, COUNTED, RECOUNT_REQUIRED
  remarks         String?

  @@index([cycleCountId])
  @@index([productId])
  @@index([warehouseId])
}

model InventoryValuationLayer {
  id                String         @id @default(uuid())
  companyId         String
  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId         String
  product           Product        @relation(fields: [productId], references: [id])
  warehouseId       String?
  warehouse         Warehouse?     @relation("ValuationWarehouse", fields: [warehouseId], references: [id])
  stockMovementId   String?
  stockMovement     StockMovement? @relation(fields: [stockMovementId], references: [id])
  layerType         String // RECEIPT, ADJUSTMENT_IN, INITIAL_STOCK
  quantity          Decimal
  remainingQuantity Decimal
  unitCost          Decimal
  totalCost         Decimal
  valuationMethod   String         @default("FIFO") // FIFO, LIFO, WEIGHTED_AVERAGE, SPECIFIC_ID, STANDARD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
}

model ReorderPolicy {
  id                              String    @id @default(uuid())
  companyId                       String
  company                         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId                       String
  product                         Product   @relation(fields: [productId], references: [id])
  warehouseId                     String
  warehouse                       Warehouse @relation("ReorderPolicyWarehouse", fields: [warehouseId], references: [id])
  minimumQuantity                 Decimal
  maximumQuantity                 Decimal
  reorderPoint                    Decimal
  reorderQuantity                 Decimal
  safetyStock                     Decimal
  leadTimeDays                    Int
  preferredSupplierId             String?
  preferredSupplier               Supplier? @relation("PreferredSupplier", fields: [preferredSupplierId], references: [id])
  autoGeneratePurchaseRequisition Boolean   @default(false)
  isActive                        Boolean   @default(true)
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  @@unique([companyId, productId, warehouseId])
  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
}

enum PurchaseRequisitionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  CONVERTED
}

enum PurchaseRequisitionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model PurchaseRequisition {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requisitionNumber String
  requestDate       DateTime @default(now())

  requestedById String?
  requestedBy   User?   @relation("PurchaseRequisitionRequestedBy", fields: [requestedById], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  status   PurchaseRequisitionStatus   @default(DRAFT)
  priority PurchaseRequisitionPriority @default(MEDIUM)

  requiredDate DateTime?
  remarks      String?

  approvedById String?
  approvedBy   User?     @relation("PurchaseRequisitionApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  lines     PurchaseRequisitionLine[]
  rfqs      RequestForQuotation[]
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  @@unique([companyId, requisitionNumber])
  @@index([companyId])
  @@index([departmentId])
  @@index([status])
}

model PurchaseRequisitionLine {
  id                    String              @id @default(uuid())
  purchaseRequisitionId String
  purchaseRequisition   PurchaseRequisition @relation(fields: [purchaseRequisitionId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  description   String
  quantity      Decimal
  uom           String
  estimatedCost Decimal?

  warehouseId String?
  warehouse   Warehouse? @relation("PurchaseRequisitionWarehouse", fields: [warehouseId], references: [id])

  remarks  String?
  rfqLines RequestForQuotationLine[]

  @@index([purchaseRequisitionId])
  @@index([productId])
  @@index([warehouseId])
}

enum RequestForQuotationStatus {
  DRAFT
  ISSUED
  CLOSED
  CANCELLED
}

enum VendorQuotationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  EXPIRED
}

model RequestForQuotation {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rfqNumber String

  purchaseRequisitionId String?
  purchaseRequisition   PurchaseRequisition? @relation(fields: [purchaseRequisitionId], references: [id])

  status      RequestForQuotationStatus @default(DRAFT)
  issueDate   DateTime?
  closingDate DateTime?
  remarks     String?

  createdById String?
  createdBy   User?   @relation("RfqCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines             RequestForQuotationLine[]
  vendorQuotations  VendorQuotation[]
  vendorComparisons VendorComparison[]

  @@unique([companyId, rfqNumber])
  @@index([companyId])
  @@index([purchaseRequisitionId])
  @@index([status])
}

model RequestForQuotationLine {
  id                    String              @id @default(uuid())
  requestForQuotationId String
  requestForQuotation   RequestForQuotation @relation(fields: [requestForQuotationId], references: [id], onDelete: Cascade)

  purchaseRequisitionLineId String?
  purchaseRequisitionLine   PurchaseRequisitionLine? @relation(fields: [purchaseRequisitionLineId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  description String
  quantity    Decimal
  uom         String
  remarks     String?

  vendorQuotationLines VendorQuotationLine[]

  @@index([requestForQuotationId])
  @@index([productId])
}

model VendorQuotation {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  requestForQuotationId String?
  requestForQuotation   RequestForQuotation? @relation(fields: [requestForQuotationId], references: [id])

  quotationDate DateTime @default(now())
  currency      String   @default("USD")

  subtotal Decimal @default(0)
  discount Decimal @default(0)
  tax      Decimal @default(0)
  shipping Decimal @default(0)
  total    Decimal @default(0)

  leadTime     String?
  paymentTerms String?
  validUntil   DateTime?

  status  VendorQuotationStatus @default(DRAFT)
  remarks String?

  lines                 VendorQuotationLine[]
  vendorComparisonItems VendorComparisonItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([supplierId])
  @@index([requestForQuotationId])
  @@index([status])
}

model VendorQuotationLine {
  id                String          @id @default(uuid())
  vendorQuotationId String
  vendorQuotation   VendorQuotation @relation(fields: [vendorQuotationId], references: [id], onDelete: Cascade)

  requestForQuotationLineId String?
  requestForQuotationLine   RequestForQuotationLine? @relation(fields: [requestForQuotationLineId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  quantity  Decimal
  unitPrice Decimal
  discount  Decimal @default(0)
  tax       Decimal @default(0)
  lineTotal Decimal @default(0)

  @@index([vendorQuotationId])
  @@index([productId])
}

enum VendorComparisonStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
  CONVERTED
}

enum EvaluationMethod {
  LOWEST_PRICE
  WEIGHTED_SCORE
  MANUAL_SELECTION
  BEST_VALUE
}

model VendorComparison {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  comparisonNumber String

  requestForQuotationId String
  requestForQuotation   RequestForQuotation @relation(fields: [requestForQuotationId], references: [id])

  status           VendorComparisonStatus @default(DRAFT)
  evaluationMethod EvaluationMethod       @default(MANUAL_SELECTION)

  selectedSupplierId String?

  remarks String?

  createdById String?
  createdBy   User?   @relation("VendorComparisonCreator", fields: [createdById], references: [id])

  approvedById String?
  approvedBy   User?     @relation("VendorComparisonApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items VendorComparisonItem[]

  @@unique([companyId, comparisonNumber])
  @@index([companyId])
  @@index([requestForQuotationId])
  @@index([status])
}

model VendorComparisonItem {
  id String @id @default(uuid())

  vendorComparisonId String
  vendorComparison   VendorComparison @relation(fields: [vendorComparisonId], references: [id], onDelete: Cascade)

  vendorQuotationId String
  vendorQuotation   VendorQuotation @relation(fields: [vendorQuotationId], references: [id])

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  totalPrice   Decimal @default(0)
  leadTime     String?
  paymentTerms String?

  qualityScore  Decimal?
  deliveryScore Decimal?
  priceScore    Decimal?
  overallScore  Decimal?

  ranking    Int?
  isSelected Boolean @default(false)
  remarks    String?

  @@index([vendorComparisonId])
  @@index([vendorQuotationId])
  @@index([supplierId])
}

model PickingTask {
  id           String            @id @default(uuid())
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId  String
  warehouse    Warehouse         @relation("PickingTaskWarehouse", fields: [warehouseId], references: [id])
  salesOrderId String?
  taskNumber   String
  status       String            @default("PENDING") // PENDING, ASSIGNED, IN_PROGRESS, PICKED, COMPLETED, CANCELLED
  priority     Int               @default(1)
  assignedToId String?
  assignedTo   Employee?         @relation("PickingTaskAssignedTo", fields: [assignedToId], references: [id])
  lines        PickingTaskLine[]
  packingTasks PackingTask[]
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([companyId, taskNumber])
  @@index([companyId])
  @@index([warehouseId])
}

model PickingTaskLine {
  id                String           @id @default(uuid())
  pickingTaskId     String
  pickingTask       PickingTask      @relation(fields: [pickingTaskId], references: [id], onDelete: Cascade)
  productId         String
  product           Product          @relation(fields: [productId], references: [id])
  batchId           String?
  batch             InventoryBatch?  @relation("PickingLineBatch", fields: [batchId], references: [id])
  serialId          String?
  serial            InventorySerial? @relation("PickingLineSerial", fields: [serialId], references: [id])
  zoneId            String
  zone              WarehouseZone    @relation("PickingLineZone", fields: [zoneId], references: [id])
  binId             String
  bin               WarehouseBin     @relation("PickingLineBin", fields: [binId], references: [id])
  requestedQuantity Decimal
  pickedQuantity    Decimal          @default(0)
  packedQuantity    Decimal          @default(0)
  remarks           String?

  @@index([pickingTaskId])
  @@index([productId])
  @@index([zoneId])
  @@index([binId])
}

model PackingTask {
  id            String      @id @default(uuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId   String
  warehouse     Warehouse   @relation("PackingTaskWarehouse", fields: [warehouseId], references: [id])
  pickingTaskId String
  pickingTask   PickingTask @relation(fields: [pickingTaskId], references: [id])
  packingNumber String
  status        String      @default("PENDING") // PENDING, PACKING, COMPLETED, CANCELLED
  packedById    String?
  packedBy      Employee?   @relation("PackingTaskPackedBy", fields: [packedById], references: [id])
  packedAt      DateTime?
  remarks       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([companyId, packingNumber])
  @@index([companyId])
  @@index([warehouseId])
  @@index([pickingTaskId])
}

// ==========================================
// Phase 3A Customer Master Models
// ==========================================

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model CustomerGroup {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers Customer[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Customer {
  id              String         @id @default(uuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerCode    String
  customerGroupId String?
  customerGroup   CustomerGroup? @relation(fields: [customerGroupId], references: [id])
  name            String
  displayName     String?
  email           String?
  phone           String?
  mobile          String?
  website         String?
  taxNumber       String?
  tradeLicense    String?
  creditLimit     Decimal        @default(0)
  creditDays      Int            @default(0)
  currency        String         @default("BDT")
  priceLevel      String?
  status          CustomerStatus @default(ACTIVE)
  notes           String?
  portalPassword  String?
  isPortalActive  Boolean        @default(false)
  createdById     String
  createdBy       User           @relation("CustomerCreator", fields: [createdById], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  addresses        CustomerAddress[]
  contacts         CustomerContact[]
  leads            Lead[]
  opportunities    Opportunity[]
  quotations       Quotation[]
  salesOrders      SalesOrder[]
  deliveryOrders   DeliveryOrder[]
  customerReturns  CustomerReturn[]
  creditProfile    CustomerCreditProfile?
  creditHistories  CustomerCreditHistory[]
  customerPayments CustomerPayment[]
  salesCommissions SalesCommission[]

  @@unique([companyId, customerCode])
  @@unique([companyId, email])
  @@unique([companyId, phone])
  @@index([companyId])
  @@index([customerGroupId])
  @@index([status])
}

model CustomerAddress {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type         String // BILLING, SHIPPING, OFFICE, WAREHOUSE
  country      String?
  state        String?
  city         String?
  postalCode   String?
  addressLine1 String
  addressLine2 String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@index([customerId])
}

model CustomerContact {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  designation String?
  email       String?
  phone       String?
  mobile      String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([customerId])
}
