model Lead {
  id           String   @id @default(uuid())
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  leadNumber   String   @unique @default(cuid())
  serialNumber Int      @default(autoincrement()) // kept for backwards compatibility

  companyName String

  // Legacy relations
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  // New V1.3 relations
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  leadSourceId    String?
  leadSourceModel LeadSource? @relation(fields: [leadSourceId], references: [id])

  contactPerson String // legacy
  contactName   String? // new
  phone         String
  mobile        String?
  email         String?
  website       String?
  industry      String?

  serviceType    String? // legacy
  expectedValue  Decimal? // legacy
  estimatedValue Decimal? // new

  assignedToId String?
  assignedTo   Employee? @relation(fields: [assignedToId], references: [id])

  nextFollowUp        DateTime? // legacy
  expectedCloseDate   DateTime? // new
  expectedClosingDate DateTime? // legacy

  status       String       @default("New") // legacy
  leadStatus   LeadStatus   @default(NEW) // new
  priority     String       @default("Medium") // legacy
  leadPriority LeadPriority @default(MEDIUM) // new
  rating       LeadRating? // new

  notes      String?
  lostReason String?
  address    String?
  tags       String[]

  leadSource String? // legacy string

  createdById String?
  createdBy   User?    @relation("LeadCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities    LeadActivity[]
  projects      Project[]
  opportunities Opportunity[]

  @@index([status])
  @@index([leadStatus])
  @@index([priority])
  @@index([rating])
  @@index([assignedToId])
  @@index([companyId])
  @@index([customerId])
  @@index([leadSourceId])
}

model LeadActivity {
