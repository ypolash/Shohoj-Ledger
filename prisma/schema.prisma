  putAwayTaskLines         PutAwayTaskLine[]
  stockTransferLines       StockTransferLine[]
  inventoryAdjustmentLines InventoryAdjustmentLine[]
  cycleCountLines          CycleCountLine[]
  inventoryValuationLayers InventoryValuationLayer[]
  reorderPolicies          ReorderPolicy[]
  purchaseRequestLines     PurchaseRequestLine[]
  pickingTaskLines         PickingTaskLine[]

  @@unique([companyId, productCode])
  @@unique([companyId, sku])
  @@index([companyId])
}

model Warehouse {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?   @relation(fields: [branchId], references: [id])
  code        String
  name        String
  description String?
  location    String?
  address     String?
  phone       String?
  email       String?
  managerId   String?
  manager     Employee? @relation("WarehouseManager", fields: [managerId], references: [id])
  status      String    @default("ACTIVE")
  isActive    Boolean   @default(true)
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stockTransactions     StockTransaction[]
  inventoryTransactions InventoryTransaction[]
  purchaseOrders        PurchaseOrder[]
  transfersFrom         StockTransfer[]        @relation("TransferFrom")
  transfersTo           StockTransfer[]        @relation("TransferTo")

  zones                    WarehouseZone[]
  bins                     WarehouseBin[]
  productWarehouses        ProductWarehouse[]
  stockMovements           StockMovement[]
  inventoryBatches         InventoryBatch[]
  inventorySerials         InventorySerial[]
  goodsReceipts            GoodsReceipt[]
  putAwayTasks             PutAwayTask[]
  inventoryAdjustments     InventoryAdjustment[]     @relation("AdjustmentWarehouse")
  inventoryAdjustmentLines InventoryAdjustmentLine[] @relation("AdjustmentLineWarehouse")
  cycleCounts              CycleCount[]              @relation("CycleCountWarehouse")
  cycleCountLines          CycleCountLine[]          @relation("CycleCountLineWarehouse")
  valuationLayers          InventoryValuationLayer[] @relation("ValuationWarehouse")
  reorderPolicies          ReorderPolicy[]           @relation("ReorderPolicyWarehouse")
  purchaseRequests         PurchaseRequest[]         @relation("PurchaseRequestWarehouse")
  pickingTasks             PickingTask[]             @relation("PickingTaskWarehouse")
  packingTasks             PackingTask[]             @relation("PackingTaskWarehouse")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([code])
}

