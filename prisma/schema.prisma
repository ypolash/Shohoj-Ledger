generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  companyId               String?
  platformRole            PlatformRole?
  name                    String
  email                   String                   @unique
  emailVerified           Boolean                  @default(false)
  image                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  role                    String                   @default("member")
  sessions                Session[]
  accounts                Account[]
  payrollAudits           PayrollAudit[]
  ledgerEntries           LedgerEntry[]
  reportAudits            ReportAudit[]
  leadActivities          LeadActivity[]
  projectActivities       ProjectActivity[]
  clientActivities        ClientActivity[]
  clientDocuments         ClientDocument[]
  stockTransactions       StockTransaction[]
  inventoryAudits         InventoryAudit[]
  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  notificationAudits      NotificationAudit[]
  globalAuditLogs         GlobalAuditLog[]
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model Project {
  id              String     @id @default(uuid())
  companyId       String?
  company         Company?   @relation(fields: [companyId], references: [id])
  projectCode     String?
  name            String
  description     String?
  category        String?
  priority        String?    @default("Medium")
  status          String     @default("Draft")
  progress        Int?       @default(0)
  clientName      String?
  clientId        String?
  client          Client?    @relation(fields: [clientId], references: [id])
  leadId          String?
  lead            Lead?      @relation(fields: [leadId], references: [id])
  managerId       String?
  manager         Employee?  @relation("ProjectManager", fields: [managerId], references: [id])
  teamMembers     Employee[] @relation("ProjectTeam")
  startDate       DateTime?
  endDate         DateTime?
  estimatedBudget Decimal?
  actualCost      Decimal?   @default(0)
  tags            String[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tasks      Task[]
  activities ProjectActivity[]

  @@unique([companyId, projectCode])
  @@index([companyId])
}

model Income {
  id            String   @id @default(uuid())
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id])
  projectId     String?
  category      String
  source        String?
  amount        Decimal
  received      Decimal  @default(0)
  paymentStatus String
  shareable     Boolean  @default(true)
  description   String?
  createdAt     DateTime @default(now())

  @@index([companyId])
}

model Expense {
  id             String   @id @default(uuid())
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  projectId      String?
  category       String
  amount         Decimal
  paymentMethod  String
  approvalStatus String
  description    String?
  createdAt      DateTime @default(now())

  @@index([companyId])
}

model FundTransaction {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  amount      Decimal
  source      String?
  description String?
  createdAt   DateTime @default(now())

  @@index([companyId])
}

model ReserveTransaction {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  type      String
  amount    Decimal
  reason    String?
  createdAt DateTime @default(now())

  @@index([companyId])
}

model MemberLoan {
  id              String   @id @default(uuid())
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])
  memberId        String
  amount          Decimal
  remainingAmount Decimal
  reason          String?
  issueDate       DateTime @default(now())
  dueDate         DateTime
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())

  @@index([companyId])
}

model Advance {
  id              String   @id @default(uuid())
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])
  memberId        String
  amount          Decimal
  remainingAmount Decimal
  reason          String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())

  @@index([companyId])
}

model Settlement {
  id             String   @id @default(uuid())
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  period         String
  status         String   @default("PENDING")
  totalIncome    Decimal
  totalExpenses  Decimal
  ceoShare       Decimal
  developerShare Decimal
  advisorShare   Decimal
  companyShare   Decimal
  createdAt      DateTime @default(now())

  @@index([companyId])
}

model IncomeCategory {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String   @unique
  createdAt DateTime @default(now())

  @@index([companyId])
}

model Member {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String
  role      String
  email     String?  @unique
  phone     String?
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Employee {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  userId      String?  @unique // Link to User model if they can log in
  employeeId  String   @unique
  password    String?
  firstName   String
  lastName    String
  email       String   @unique
  phone       String?
  designation String
  department  String?
  joinDate    DateTime
  basicSalary Decimal
  status      String   @default("ACTIVE") // ACTIVE, ON_LEAVE, TERMINATED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendances    Attendance[]
  leaveRequests  LeaveRequest[]
  salaryPayments SalaryPayment[]
  deductions     SalaryDeduction[]
  bonuses        Bonus[]
  payslips       Payslip[]
  tasks          Task[]

  departmentId  String?
  departmentRef Department? @relation("EmployeeDepartment", fields: [departmentId], references: [id])

  designationId  String?
  designationRef Designation? @relation("EmployeeDesignation", fields: [designationId], references: [id])

  reportingManagerId String?
  reportingManager   Employee?  @relation("EmployeeToManager", fields: [reportingManagerId], references: [id])
  subordinates       Employee[] @relation("EmployeeToManager")

  headOfDepartment Department[] @relation("DepartmentHead")

  employmentType   String?
  location         String?
  shift            String?
  employmentStatus String? @default("Probation")

  lifecycleEvents   EmployeeLifecycle[]
  leads             Lead[]
  managedProjects   Project[]           @relation("ProjectManager")
  teamProjects      Project[]           @relation("ProjectTeam")
  managedWarehouses Warehouse[]         @relation("WarehouseManager")
  assignedAssets    Asset[]             @relation("EmployeeAssets")

  @@index([companyId])
}

model Task {
  id                   String    @id @default(uuid())
  companyId            String?
  company              Company?  @relation(fields: [companyId], references: [id])
  projectId            String?
  project              Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedToEmployeeId String?
  employee             Employee? @relation(fields: [assignedToEmployeeId], references: [employeeId])
  title                String
  description          String?
  priority             String?   @default("Medium")
  status               String    @default("To Do") // To Do, In Progress, Review, Testing, Completed
  dueDate              DateTime?
  estimatedHours       Decimal?  @default(0)
  actualHours          Decimal?  @default(0)
  checklist            Json?
  attachments          Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([companyId])
  @@index([projectId])
}

model Attendance {
  id                  String    @id @default(uuid())
  companyId           String?
  company             Company?  @relation(fields: [companyId], references: [id])
  employeeId          String
  employee            Employee  @relation(fields: [employeeId], references: [id])
  date                DateTime // Store just the date (YYYY-MM-DD)
  checkInTime         DateTime? @map("checkIn")
  checkInLocation     String?
  checkOutTime        DateTime? @map("checkOut")
  checkOutLocation    String?
  status              String // PRESENT, LATE, ABSENT, HALF_DAY, WEEKLY_OFF, OFF_DAY_WORK
  isLate              Boolean   @default(false)
  lateMinutes         Int       @default(0)
  totalWorkingMinutes Int?      @default(0)
  earlyLeaveMinutes   Int?      @default(0)
  overtimeMinutes     Int?      @default(0)
  punishmentReason    String?
  reviewStatus        String?
  punishmentAmount    Decimal?  @default(0)
  latitude            Float?
  longitude           Float?
  wifiSsid            String?
  wifiBssid           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([employeeId, date])
  @@index([companyId])
}

model LeaveRequest {
  id         String   @id @default(uuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String // CASUAL, SICK, UNPAID
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
}

model SalaryPayment {
  id             String    @id @default(uuid())
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id])
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id])
  month          Int // 1-12
  year           Int
  basicSalary    Decimal
  grossSalary    Decimal
  netSalary      Decimal
  paymentDate    DateTime?
  status         String    @default("PAID") // DRAFT, CALCULATED, SUBMITTED, APPROVED, PAID, LOCKED, ARCHIVED
  expenseId      String? // Link to Expense model record in Shohoj Ledger
  paymentMethod  String?
  transactionRef String?
  paymentNote    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  audits PayrollAudit[]

  @@index([companyId])
}

model SalaryDeduction {
  id         String   @id @default(uuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  month      Int
  year       Int
  type       String // LATE_FEE, UNPAID_LEAVE, OTHER
  amount     Decimal
  reason     String?
  createdAt  DateTime @default(now())

  @@index([companyId])
}

model Bonus {
  id         String   @id @default(uuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  month      Int
  year       Int
  type       String // PERFORMANCE, FESTIVAL, OTHER
  amount     Decimal
  reason     String?
  expenseId  String? // Link to Expense model record
  createdAt  DateTime @default(now())

  @@index([companyId])
}

model Payslip {
  id              String   @id @default(uuid())
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  month           Int
  year            Int
  fileUrl         String? // If storing PDF generated
  totalEarnings   Decimal
  totalDeductions Decimal
  netPay          Decimal
  createdAt       DateTime @default(now())

  @@unique([employeeId, month, year])
  @@index([companyId])
}

model Lead {
  id                  String         @id @default(uuid())
  companyId           String?
  company             Company?       @relation(fields: [companyId], references: [id])
  serialNumber        Int            @default(autoincrement())
  companyName         String
  clientId            String?
  client              Client?        @relation(fields: [clientId], references: [id])
  contactPerson       String
  phone               String
  email               String?
  serviceType         String
  expectedValue       Decimal
  leadSource          String?
  assignedToId        String?
  assignedTo          Employee?      @relation(fields: [assignedToId], references: [id])
  nextFollowUp        DateTime?
  notes               String?
  status              String         @default("New")
  priority            String         @default("Medium")
  lostReason          String?
  website             String?
  address             String?
  industry            String?
  expectedClosingDate DateTime?
  tags                String[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  activities          LeadActivity[]
  projects            Project[]

  @@index([status])
  @@index([serviceType])
  @@index([nextFollowUp])
  @@index([assignedToId])
  @@index([companyId])
}

model LeadActivity {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type          String // CREATED, UPDATED, STATUS_CHANGE, ASSIGNED, FOLLOW_UP_CALL, FOLLOW_UP_MEETING, FOLLOW_UP_EMAIL, FOLLOW_UP_WHATSAPP, FOLLOW_UP_TASK, FOLLOW_UP_REMINDER
  description   String?
  oldValue      String?
  newValue      String?
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([companyId])
  @@index([leadId])
}

model AllowedNetwork {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String
  ssid      String
  bssid     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model PunishmentSetting {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  type        String // LATE, EARLY_LEAVE, ABSENT
  fromMinutes Int
  toMinutes   Int
  amount      Decimal
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

model AttendanceConfig {
  id                        String   @id @default(uuid())
  companyId                 String?
  company                   Company? @relation(fields: [companyId], references: [id])
  gracePeriod               Int      @default(15)
  shiftStart                String   @default("09:00") // HH:mm
  shiftEnd                  String   @default("20:00") // HH:mm
  fridayOff                 Boolean  @default(true)
  enablePunishmentDeduction Boolean  @default(false)

  @@index([companyId])
}

enum BusinessType {
  PRODUCT
  SERVICE
  BOTH
}

enum CompanyStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum PlatformRole {
  SUPER_ADMIN
  USER
}

model Company {
  id                      String                   @id @default(uuid())
  name                    String
  businessType            String
  status                  String                   @default("ACTIVE")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  settings                CompanySetting?
  modules                 CompanyModule[]
  roles                   Role[]
  projects                Project[]
  incomes                 Income[]
  expenses                Expense[]
  fundTransactions        FundTransaction[]
  reserveTransactions     ReserveTransaction[]
  memberLoans             MemberLoan[]
  advances                Advance[]
  settlements             Settlement[]
  incomeCategories        IncomeCategory[]
  members                 Member[]
  employees               Employee[]
  tasks                   Task[]
  attendances             Attendance[]
  leaveRequests           LeaveRequest[]
  salaryPayments          SalaryPayment[]
  salaryDeductions        SalaryDeduction[]
  bonuses                 Bonus[]
  payslips                Payslip[]
  leads                   Lead[]
  allowedNetworks         AllowedNetwork[]
  punishmentSettings      PunishmentSetting[]
  attendanceConfigs       AttendanceConfig[]
  departments             Department[]
  designations            Designation[]
  lifecycles              EmployeeLifecycle[]
  payrollAudits           PayrollAudit[]
  ledgerEntries           LedgerEntry[]
  reportAudits            ReportAudit[]
  leadActivities          LeadActivity[]
  projectActivities       ProjectActivity[]
  clients                 Client[]
  productCategories       ProductCategory[]
  products                Product[]
  warehouses              Warehouse[]
  suppliers               Supplier[]
  purchaseOrders          PurchaseOrder[]
  stockTransactions       StockTransaction[]
  assetCategories         AssetCategory[]
  assets                  Asset[]
  inventoryAudits         InventoryAudit[]
  notificationPreferences NotificationPreference[]
  notificationTemplates   NotificationTemplate[]
  notifications           Notification[]
  announcements           Announcement[]
  notificationAudits      NotificationAudit[]
  globalAuditLogs         GlobalAuditLog[]
}

model CompanySetting {
  id                 String  @id @default(uuid())
  companyId          String  @unique
  company            Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currency           String  @default("BDT")
  timezone           String  @default("Asia/Dhaka")
  workingDays        Json
  weeklyHolidays     Json
  shiftStartTime     String
  shiftEndTime       String
  gracePeriodMinutes Int
}

model Module {
  id          String          @id @default(uuid())
  key         String          @unique
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  companies   CompanyModule[]
}

model CompanyModule {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  moduleId  String
  module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  isActive  Boolean @default(true)

  @@unique([companyId, moduleId])
}

model Role {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  isDefault   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
}

model Permission {
  id        String           @id @default(uuid())
  action    String           @unique
  moduleKey String
  roles     RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Department {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code        String?
  name        String
  description String?
  headId      String?
  head        Employee? @relation("DepartmentHead", fields: [headId], references: [id])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employees Employee[] @relation("EmployeeDepartment")

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId])
}

model Designation {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  grade       String?
  level       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[] @relation("EmployeeDesignation")

  @@unique([companyId, name])
  @@index([companyId])
}

model EmployeeLifecycle {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  eventType     String // HIRE, CONFIRM, PROMOTE, TRANSFER, SUSPEND, REINSTATE, RESIGN, TERMINATE
  effectiveDate DateTime
  description   String?
  previousData  Json? // To keep history of what changed
  newData       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
}

model PayrollAudit {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salaryPaymentId String
  salaryPayment   SalaryPayment @relation(fields: [salaryPaymentId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  role            String
  oldStatus       String?
  newStatus       String
  remarks         String?
  createdAt       DateTime      @default(now())

  @@index([companyId])
  @@index([salaryPaymentId])
}

model LedgerEntry {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  date        DateTime @default(now())
  voucherNo   String
  voucherType String

  referenceId String?
  module      String

  accountType String
  debit       Decimal @default(0)
  credit      Decimal @default(0)

  status      String  @default("COMPLETED")
  description String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([date])
  @@index([voucherNo])
  @@index([module])
}

model ReportAudit {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  reportName String
  action     String // "GENERATED", "EXPORTED", "PRINTED"
  format     String? // "CSV", "PDF"
  filters    Json?
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([reportName])
}

model ProjectActivity {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId        String? // Optional, if activity relates to a specific task
  type          String // PROJECT_CREATED, PROJECT_UPDATED, PROJECT_STATUS, TASK_CREATED, TASK_ASSIGNED, TASK_STATUS
  description   String?
  oldValue      String?
  newValue      String?
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([companyId])
  @@index([projectId])
  @@index([taskId])
}

model Client {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientCode   String
  name         String
  email        String?
  phone        String?
  altPhone     String?
  website      String?
  industry     String?
  businessType String?
  taxNumber    String?
  address      String?
  country      String?
  city         String?
  postalCode   String?
  status       String   @default("ACTIVE")
  notes        String?
  tags         String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contacts   ClientContact[]
  documents  ClientDocument[]
  activities ClientActivity[]
  projects   Project[]
  leads      Lead[]

  @@unique([companyId, clientCode])
  @@unique([companyId, email])
  @@unique([companyId, phone])
  @@unique([companyId, taxNumber])
  @@index([companyId])
}

model ClientContact {
  id          String    @id @default(uuid())
  companyId   String
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  designation String?
  email       String?
  phone       String?
  mobile      String?
  birthday    DateTime?
  notes       String?
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([clientId])
}

model ClientDocument {
  id           String   @id @default(uuid())
  companyId    String
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  type         String
  fileUrl      String
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([clientId])
}

model ClientActivity {
  id            String   @id @default(uuid())
  companyId     String
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type          String
  description   String?
  oldValue      String?
  newValue      String?
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([companyId])
  @@index([clientId])
}

model ProductCategory {
  id          String            @id @default(uuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  parentId    String?
  parent      ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryHierarchy")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  products Product[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Product {
  id            String           @id @default(uuid())
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productCode   String
  barcode       String?
  sku           String?
  name          String
  description   String?
  categoryId    String?
  category      ProductCategory? @relation(fields: [categoryId], references: [id])
  brand         String?
  unit          String?
  purchasePrice Decimal          @default(0)
  sellingPrice  Decimal          @default(0)
  minStock      Int              @default(0)
  maxStock      Int              @default(0)
  reorderLevel  Int              @default(0)
  status        String           @default("ACTIVE")
  imageUrl      String?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  stockTransactions StockTransaction[]
  purchaseItems     PurchaseOrderItem[]

  @@unique([companyId, productCode])
  @@unique([companyId, sku])
  @@index([companyId])
}

model Warehouse {
  id        String    @id @default(uuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code      String
  name      String
  location  String?
  managerId String?
  manager   Employee? @relation("WarehouseManager", fields: [managerId], references: [id])
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  stockTransactions StockTransaction[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Supplier {
  id                 String   @id @default(uuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  contactPerson      String?
  email              String?
  phone              String?
  address            String?
  paymentTerms       String?
  outstandingBalance Decimal  @default(0)
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@unique([companyId, name])
  @@index([companyId])
}

model PurchaseOrder {
  id           String    @id @default(uuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier  @relation(fields: [supplierId], references: [id])
  poNumber     String
  orderDate    DateTime  @default(now())
  expectedDate DateTime?
  status       String    @default("PENDING")
  supplierRef  String?
  totalAmount  Decimal   @default(0)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  items             PurchaseOrderItem[]
  stockTransactions StockTransaction[]

  @@unique([companyId, poNumber])
  @@index([companyId])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  companyId       String
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  unitPrice       Decimal
  totalPrice      Decimal
  receivedQty     Int           @default(0)
  returnedQty     Int           @default(0)

  @@index([companyId])
}

model StockTransaction {
  id              String         @id @default(uuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId     String
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  type            String
  quantity        Int
  reference       String?
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  notes           String?
  createdAt       DateTime       @default(now())
  performedById   String
  performedBy     User           @relation(fields: [performedById], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
}

model AssetCategory {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Asset {
  id               String        @id @default(uuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assetCode        String
  name             String
  categoryId       String
  category         AssetCategory @relation(fields: [categoryId], references: [id])
  purchaseDate     DateTime?
  purchasePrice    Decimal       @default(0)
  warrantyExpDate  DateTime?
  serialNumber     String?
  currentLocation  String?
  depreciationRate Decimal       @default(0)
  status           String        @default("ACTIVE")
  assignedToId     String?
  assignedTo       Employee?     @relation("EmployeeAssets", fields: [assignedToId], references: [id])
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([companyId, assetCode])
  @@index([companyId])
}

model InventoryAudit {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  action        String
  entityType    String
  entityId      String
  description   String?
  oldValue      String?
  newValue      String?
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([companyId])
}

model NotificationPreference {
  id                String   @id @default(uuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled      Boolean  @default(true)
  inAppEnabled      Boolean  @default(true)
  smsEnabled        Boolean  @default(false)
  pushEnabled       Boolean  @default(false)
  mutedCategories   String[] // e.g., ["CRM", "INVENTORY"]
  digestMode        Boolean  @default(false)
  workingHoursStart String? // e.g., "09:00"
  workingHoursEnd   String? // e.g., "18:00"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([companyId, userId])
  @@index([companyId])
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  category  String // e.g., "HR", "PAYROLL", "SYSTEM"
  subject   String
  body      String // Supports variables like {{EmployeeName}}
  channels  String[] // e.g., ["EMAIL", "IN_APP"]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Notification {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String // e.g., "SYSTEM", "HR", "PAYROLL", "PROJECTS"
  title     String
  message   String
  link      String?
  channel   String   @default("IN_APP")
  status    String   @default("UNREAD") // UNREAD, READ, ARCHIVED
  priority  String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, userId, status])
  @@index([companyId])
}

model Announcement {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title      String
  message    String
  targetType String // EVERYONE, DEPARTMENT, ROLE, EMPLOYEE
  targetId   String? // ID of the specific target
  priority   String   @default("NORMAL")
  status     String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
}

model NotificationAudit {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  action        String // SENT, READ, DELETED, TEMPLATE_UPDATED
  entityType    String // NOTIFICATION, ANNOUNCEMENT, TEMPLATE
  entityId      String
  description   String?
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([companyId])
}

model GlobalAuditLog {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  module      String // HR, PAYROLL, INVENTORY, SYSTEM, CRM, etc.
  entityType  String // Employee, Project, etc.
  entityId    String
  action      String // CREATE, UPDATE, DELETE, LOGIN, EXPORT
  description String?
  beforeValue String? // JSON stringified
  afterValue  String? // JSON stringified
  ipAddress   String?
  userAgent   String?
  status      String   @default("SUCCESS") // SUCCESS, FAILED
  createdAt   DateTime @default(now())

  @@index([companyId, module])
  @@index([companyId, userId])
  @@index([companyId, entityType, entityId])
}
