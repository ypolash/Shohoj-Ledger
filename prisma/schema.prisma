  conditions Json?
  createdAt  DateTime @default(now())
}

model WorkflowExecution {
  id           String                  @id @default(uuid())
  companyId    String
  company      Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workflowId   String
  workflow     Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  triggerData  Json?
  status       WorkflowExecutionStatus @default(PENDING)
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  createdAt    DateTime                @default(now())

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model ApprovalFlow {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  moduleKey   String
  isActive    Boolean  @default(true)
  createdById String
  createdBy   User     @relation("ApprovalFlowCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps    ApprovalStep[]
  requests ApprovalRequest[]

  @@index([companyId])
  @@index([moduleKey])
}

model ApprovalStep {
  id             String       @id @default(uuid())
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  approvalFlowId String
  approvalFlow   ApprovalFlow @relation(fields: [approvalFlowId], references: [id], onDelete: Cascade)
  stepOrder      Int
