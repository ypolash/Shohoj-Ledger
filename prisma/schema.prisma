  reportId       String
  report         ReportTemplate       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role                 @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionType ReportPermissionType
}

model ReportExecution {
  id            String                @id @default(uuid())
  companyId     String
  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportId      String
  report        ReportTemplate        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User                  @relation("ReportExecutionRequester", fields: [requestedById], references: [id])
  format        ReportFormat
  status        ReportExecutionStatus @default(PENDING)
  fileUrl       String?
  parameters    Json?
  createdAt     DateTime              @default(now())
  completedAt   DateTime?

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model ScheduledReport {
  id         String         @id @default(uuid())
  companyId  String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportId   String
  report     ReportTemplate @relation(fields: [reportId], references: [id], onDelete: Cascade)
  schedule   String
  recipients Json
  isActive   Boolean        @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  createdAt  DateTime       @default(now())

  @@index([companyId])
  @@index([nextRunAt])
}

model ApiKey {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String
  secretHash  String
  permissions Json?
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)
  createdById String
  createdBy   User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([companyId])
  @@index([keyHash])
}

model Webhook {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  url         String
  eventKey    String
  secret      String
  isActive    Boolean  @default(true)
  createdById String
  createdBy   User     @relation("WebhookCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([companyId])
  @@index([eventKey])
}

model WebhookDelivery {
  id           String        @id @default(uuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  webhookId    String
  webhook      Webhook       @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventKey     String
  payload      Json?
  status       WebhookStatus @default(PENDING)
  responseCode Int?
  responseBody String?
  attempts     Int           @default(0)
  createdAt    DateTime      @default(now())
  completedAt  DateTime?

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

enum BranchRoleType {
  MANAGER
  STAFF
  VIEWER
}

model Branch {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String
  address   String?
  phone     String?
  email     String?
  managerId String?
  manager   User?    @relation("BranchManager", fields: [managerId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branchUsers       BranchUser[]
  branchPermissions BranchPermission[]
  warehouses        Warehouse[]
  journalEntries    JournalEntry[]
  ledgerEntries     LedgerEntry[]

  @@index([companyId])
  @@index([code])
}

model BranchUser {
  id        String         @id @default(uuid())
  branchId  String
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleType  BranchRoleType
  createdAt DateTime       @default(now())

  @@index([branchId])
  @@index([userId])
}

model BranchPermission {
  id           String     @id @default(uuid())
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([branchId])
  @@index([roleId])
}

model InventoryTransaction {
  id              String                   @id @default(uuid())
  companyId       String
  company         Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId     String
  warehouse       Warehouse                @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId       String?
  transactionType InventoryTransactionType
  quantity        Decimal
  referenceType   String
  referenceId     String?
  createdById     String
  createdBy       User                     @relation("InventoryTransactionCreator", fields: [createdById], references: [id])
  createdAt       DateTime                 @default(now())

  @@index([companyId])
  @@index([warehouseId])
  @@index([createdAt])
}

model StockTransfer {
  id              String              @id @default(uuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromWarehouseId String
  fromWarehouse   Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  status          StockTransferStatus @default(PENDING)
  createdById     String
  createdBy       User                @relation("StockTransferCreator", fields: [createdById], references: [id])
  createdAt       DateTime            @default(now())
  completedAt     DateTime?

  @@index([companyId])
  @@index([status])
}

model AnalyticsSnapshot {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  metricKey   String
  metricValue Decimal?
  metadata    Json?
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([metricKey])
  @@index([periodStart])
}

model BusinessInsight {
  id          String          @id @default(uuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        InsightType
  title       String
  description String          @db.Text
  severity    InsightSeverity
  metadata    Json?
  isRead      Boolean         @default(false)
  userId      String?
  user        User?           @relation(fields: [userId], references: [id])
  createdAt   DateTime        @default(now())

  @@index([companyId])
  @@index([type])
  @@index([isRead])
}

model ForecastRecord {
  id             String   @id @default(uuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  metricKey      String
  forecastPeriod String
  predictedValue Decimal?
  confidence     Decimal?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([companyId])
  @@index([metricKey])
  @@index([forecastPeriod])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalType {
  GENERAL
  SALES
  PURCHASE
  CASH
  BANK
  PAYROLL
}

model ChartOfAccount {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountCode String
  accountName String
  accountType AccountType
  parentId    String?
  parent      ChartOfAccount?  @relation("ChartOfAccountParent", fields: [parentId], references: [id])
  children    ChartOfAccount[] @relation("ChartOfAccountParent")
  isSystem    Boolean          @default(false)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  journalEntryLines JournalEntryLine[]
  ledgerEntries     LedgerEntry[]

  @@unique([companyId, accountCode])
  @@index([companyId])
  @@index([accountCode])
}

model FiscalYear {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())

  periods AccountingPeriod[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([isClosed])
}

model AccountingPeriod {
  id           String     @id @default(uuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYearId String
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  name         String
  startDate    DateTime
  endDate      DateTime
  isClosed     Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@unique([companyId, fiscalYearId, name])
  @@index([companyId])
  @@index([fiscalYearId])
}

model Journal {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code        String
  name        String
  journalType JournalType
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  journalEntries JournalEntry[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([code])
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
  CANCELLED
}

model JournalEntry {
  id            String             @id @default(uuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?            @relation(fields: [branchId], references: [id])
  journalId     String
  journal       Journal            @relation(fields: [journalId], references: [id])
  entryNumber   String
  entryDate     DateTime
  description   String?
  referenceType String?
  referenceId   String?
  status        JournalEntryStatus @default(DRAFT)
  createdById   String
  createdBy     User               @relation("JournalEntryCreator", fields: [createdById], references: [id])
  approvedById  String?
  approvedBy    User?              @relation("JournalEntryApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  lines         JournalEntryLine[]
  ledgerEntries LedgerEntry[]

  @@unique([companyId, entryNumber])
  @@index([companyId])
  @@index([entryDate])
  @@index([status])
  @@index([journalId])
}

model JournalEntryLine {
  id             String         @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  description    String?
  debit          Decimal        @default(0)
  credit         Decimal        @default(0)
  createdAt      DateTime       @default(now())
  ledgerEntries  LedgerEntry[]

  @@index([journalEntryId])
}

model WarehouseZone {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  code        String
  name        String
  description String?
  isActive    Boolean   @default(true)

  bins           WarehouseBin[]
  stockMovements StockMovement[]

  @@index([warehouseId])
  @@index([code])
}

model WarehouseBin {
  id          String         @id @default(uuid())
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  zoneId      String?
  zone        WarehouseZone? @relation(fields: [zoneId], references: [id])
  code        String
  name        String
  capacity    Decimal?
  isActive    Boolean        @default(true)

  productWarehouses ProductWarehouse[]
  stockMovements    StockMovement[]

  @@index([warehouseId])
  @@index([code])
}

model ProductWarehouse {
  id               String        @id @default(uuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId        String
  product          Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId      String
  warehouse        Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  binId            String?
  bin              WarehouseBin? @relation(fields: [binId], references: [id])
  quantity         Decimal       @default(0)
  reservedQuantity Decimal       @default(0)
  minimumQuantity  Decimal       @default(0)
  maximumQuantity  Decimal?
  reorderPoint     Decimal       @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
}

model StockMovement {
  id          String         @id @default(uuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId   String
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  zoneId      String?
  zone        WarehouseZone? @relation(fields: [zoneId], references: [id])
  binId       String?
  bin         WarehouseBin?  @relation(fields: [binId], references: [id])

  movementType  String
  referenceType String
  referenceId   String

  quantity      Decimal
  unitCost      Decimal?
  balanceAfter  Decimal
  remarks       String?
  performedById String?
  performedBy   Employee? @relation(fields: [performedById], references: [id])
  createdAt     DateTime  @default(now())

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
  @@index([referenceType, referenceId])
}
