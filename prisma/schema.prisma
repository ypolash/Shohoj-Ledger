generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                   @id @default(uuid())
  companyId                     String?
  platformRole                  PlatformRole?
  name                          String
  email                         String                   @unique
  emailVerified                 Boolean                  @default(false)
  image                         String?
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt
  role                          String                   @default("member")
  sessions                      Session[]
  accounts                      Account[]
  payrollAudits                 PayrollAudit[]
  ledgerEntries                 LedgerEntry[]
  reportAudits                  ReportAudit[]
  jobOpenings                   JobOpening[]
  leadActivities                LeadActivity[]
  projectActivities             ProjectActivity[]
  clientActivities              ClientActivity[]
  clientDocuments               ClientDocument[]
  stockTransactions             StockTransaction[]
  inventoryAudits               InventoryAudit[]
  notificationPreferences       NotificationPreference[]
  notifications                 Notification[]
  notificationAudits            NotificationAudit[]
  globalAuditLogs               GlobalAuditLog[]
  auditEvents                   AuditEvent[]
  createdWorkflows              Workflow[]               @relation("WorkflowCreator")
  approvalFlows                 ApprovalFlow[]           @relation("ApprovalFlowCreator")
  approvalRequests              ApprovalRequest[]        @relation("ApprovalRequester")
  approvalHistories             ApprovalHistory[]
  createdReportTemplates        ReportTemplate[]         @relation("ReportTemplateCreator")
  reportExecutions              ReportExecution[]        @relation("ReportExecutionRequester")
  notificationQueues            NotificationQueue[]
  apiKeys                       ApiKey[]                 @relation("ApiKeyCreator")
  webhooks                      Webhook[]                @relation("WebhookCreator")
  managedBranches               Branch[]                 @relation("BranchManager")
  branchUsers                   BranchUser[]
  createdPurchaseOrders         PurchaseOrder[]          @relation("PurchaseOrderCreator")
  createdInventoryTx            InventoryTransaction[]   @relation("InventoryTransactionCreator")
  businessInsights              BusinessInsight[]
  createdJournalEntries         JournalEntry[]           @relation("JournalEntryCreator")
  approvedJournalEntries        JournalEntry[]           @relation("JournalEntryApprover")
  createdCustomers              Customer[]               @relation("CustomerCreator")
  createdLeads                  Lead[]                   @relation("LeadCreator")
  createdLeadActivities         LeadActivity[]           @relation("LeadActivityCreator")
  createdOpportunities          Opportunity[]            @relation("OpportunityCreator")
  createdOppActivities          OpportunityActivity[]    @relation("OpportunityActivityCreator")
  createdQuotations             Quotation[]              @relation("QuotationCreator")
  createdSalesOrders            SalesOrder[]             @relation("SalesOrderCreator")
  createdDeliveryOrders         DeliveryOrder[]          @relation("DeliveryOrderCreator")
  createdCustomerReturns        CustomerReturn[]         @relation("CustomerReturnCreator")
  createdCreditHistories        CustomerCreditHistory[]  @relation("CreditHistoryCreator")
  createdCustomerPayments       CustomerPayment[]        @relation("CustomerPaymentCreator")
  salesCommissions              SalesCommission[]        @relation("CommissionSalesperson")
  createdSuppliers              Supplier[]               @relation("SupplierCreator")
  purchaseRequisitionsRequested PurchaseRequisition[]    @relation("PurchaseRequisitionRequestedBy")
  purchaseRequisitionsApproved  PurchaseRequisition[]    @relation("PurchaseRequisitionApprovedBy")
  createdRfqs                   RequestForQuotation[]    @relation("RfqCreator")
  createdVendorComparisons      VendorComparison[]       @relation("VendorComparisonCreator")
  approvedVendorComparisons     VendorComparison[]       @relation("VendorComparisonApprover")
  approvedPurchaseOrders        PurchaseOrder[]          @relation("PurchaseOrderApprover")
  createdGoodsReceiptNotes      GoodsReceiptNote[]       @relation("GoodsReceiptCreator")
  approvedGoodsReceiptNotes     GoodsReceiptNote[]       @relation("GoodsReceiptApprover")
  createdSupplierInvoices       SupplierInvoice[]        @relation("SupplierInvoiceCreator")
  approvedSupplierInvoices      SupplierInvoice[]        @relation("SupplierInvoiceApprover")
  createdSupplierPayments       SupplierPayment[]        @relation("SupplierPaymentCreator")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model Project {
  id              String     @id @default(uuid())
  companyId       String?
  company         Company?   @relation(fields: [companyId], references: [id])
  projectCode     String?
  name            String
  description     String?
  category        String?
  priority        String?    @default("Medium")
  status          String     @default("Draft")
  progress        Int?       @default(0)
  clientName      String?
  clientId        String?
  client          Client?    @relation(fields: [clientId], references: [id])
  leadId          String?
  lead            Lead?      @relation(fields: [leadId], references: [id])
  managerId       String?
  manager         Employee?  @relation("ProjectManager", fields: [managerId], references: [id])
  teamMembers     Employee[] @relation("ProjectTeam")
  startDate       DateTime?
  endDate         DateTime?
  estimatedBudget Decimal?
  actualCost      Decimal?   @default(0)
  tags            String[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tasks      Task[]
  activities ProjectActivity[]

  @@unique([companyId, projectCode])
  @@index([companyId])
}

model Income {
  id            String   @id @default(uuid())
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id])
  projectId     String?
  category      String
  source        String?
  amount        Decimal
  received      Decimal  @default(0)
  paymentStatus String
  shareable     Boolean  @default(true)
  description   String?
  createdAt     DateTime @default(now())

  @@index([companyId])
}

model Expense {
  id             String   @id @default(uuid())
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  projectId      String?
  category       String
  amount         Decimal
  paymentMethod  String
  approvalStatus String
  description    String?
  createdAt      DateTime @default(now())

  @@index([companyId])
}

model FundTransaction {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  amount      Decimal
  source      String?
  description String?
  createdAt   DateTime @default(now())

  @@index([companyId])
}

model ReserveTransaction {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  type      String
  amount    Decimal
  reason    String?
  createdAt DateTime @default(now())

  @@index([companyId])
}

model MemberLoan {
  id              String   @id @default(uuid())
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])
  memberId        String
  amount          Decimal
  remainingAmount Decimal
  reason          String?
  issueDate       DateTime @default(now())
  dueDate         DateTime
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())

  @@index([companyId])
}

model Advance {
  id              String   @id @default(uuid())
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])
  memberId        String
  amount          Decimal
  remainingAmount Decimal
  reason          String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())

  @@index([companyId])
}

model Settlement {
  id             String   @id @default(uuid())
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  period         String
  status         String   @default("PENDING")
  totalIncome    Decimal
  totalExpenses  Decimal
  ceoShare       Decimal
  developerShare Decimal
  advisorShare   Decimal
  companyShare   Decimal
  createdAt      DateTime @default(now())

  @@index([companyId])
}

model IncomeCategory {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String   @unique
  createdAt DateTime @default(now())

  @@index([companyId])
}

model Member {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String
  role      String
  email     String?  @unique
  phone     String?
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Employee {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  userId      String?  @unique // Link to User model if they can log in
  employeeId  String   @unique
  password    String?
  firstName   String
  lastName    String
  email       String   @unique
  phone       String?
  designation String
  department  String?
  joinDate    DateTime
  basicSalary Decimal
  status      String   @default("ACTIVE") // ACTIVE, ON_LEAVE, TERMINATED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendances    Attendance[]
  leaveRequests  LeaveRequest[]
  salaryPayments SalaryPayment[]
  deductions     SalaryDeduction[]
  bonuses        Bonus[]
  payslips       Payslip[]
  tasks          Task[]

  departmentId  String?
  departmentRef Department? @relation("EmployeeDepartment", fields: [departmentId], references: [id])

  designationId  String?
  designationRef Designation? @relation("EmployeeDesignation", fields: [designationId], references: [id])

  reportingManagerId String?
  reportingManager   Employee?  @relation("EmployeeToManager", fields: [reportingManagerId], references: [id])
  subordinates       Employee[] @relation("EmployeeToManager")

  headOfDepartment Department[] @relation("DepartmentHead")
  headOfDivision   Division[]   @relation("DivisionHead")
  headOfSection    Section[]    @relation("SectionHead")
  leadOfTeam       Team[]       @relation("TeamLead")

  employmentType   String?
  location         String?
  shift            String?
  employmentStatus String? @default("Probation")

  branchId        String?
  branch          Branch?        @relation(fields: [branchId], references: [id])
  divisionId      String?
  division        Division?      @relation(fields: [divisionId], references: [id])
  sectionId       String?
  section         Section?       @relation(fields: [sectionId], references: [id])
  teamId          String?
  team            Team?          @relation(fields: [teamId], references: [id])
  jobPositionId   String?
  jobPosition     JobPosition?   @relation(fields: [jobPositionId], references: [id])
  employeeGradeId String?
  employeeGrade   EmployeeGrade? @relation(fields: [employeeGradeId], references: [id])
  costCenterId    String?
  costCenter      CostCenter?    @relation(fields: [costCenterId], references: [id])
  workShiftId     String?
  workShift       WorkShift?     @relation(fields: [workShiftId], references: [id])

  profile           EmployeeProfile?
  addresses         EmployeeAddress[]
  emergencyContacts EmployeeEmergencyContact[]
  education         EmployeeEducation[]
  experience        EmployeeExperience[]
  documents         EmployeeDocument[]
  reporting         EmployeeReporting[]        @relation("EmployeeToReporting")
  managedReporting  EmployeeReporting[]        @relation("ManagerToReporting")

  lifecycleEvents              EmployeeLifecycle[]
  leads                        Lead[]
  managedProjects              Project[]             @relation("ProjectManager")
  teamProjects                 Project[]             @relation("ProjectTeam")
  managedWarehouses            Warehouse[]           @relation("WarehouseManager")
  assignedAssets               Asset[]               @relation("EmployeeAssets")
  stockMovements               StockMovement[]
  barcodes                     Barcode[]
  putAwayTasks                 PutAwayTask[]
  transfersRequested           StockTransfer[]       @relation("TransferRequestedBy")
  transfersApproved            StockTransfer[]       @relation("TransferApprovedBy")
  inventoryAdjustmentsCreated  InventoryAdjustment[] @relation("AdjustmentCreatedBy")
  inventoryAdjustmentsApproved InventoryAdjustment[] @relation("AdjustmentApprovedBy")
  cycleCountsCreated           CycleCount[]          @relation("CycleCountCreatedBy")
  cycleCountsApproved          CycleCount[]          @relation("CycleCountApprovedBy")

  pickingTasksAssigned PickingTask[] @relation("PickingTaskAssignedTo")
  packingTasksPacked   PackingTask[] @relation("PackingTaskPackedBy")
  ownedOpportunities   Opportunity[] @relation("OpportunityOwner")

  interviewsConducted Interview[]
  interviewFeedbacks  InterviewFeedback[]

  exceptions         AttendanceException[]
  adjustments        AttendanceAdjustment[]
  overtimes          AttendanceOvertime[]
  shiftAssignments   AttendanceShiftAssignment[]
  rosters            AttendanceRoster[]
  holidayAssignments AttendanceHolidayAssignment[]

  @@index([companyId])
}

model Task {
  id                   String    @id @default(uuid())
  companyId            String?
  company              Company?  @relation(fields: [companyId], references: [id])
  projectId            String?
  project              Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedToEmployeeId String?
  employee             Employee? @relation(fields: [assignedToEmployeeId], references: [employeeId])
  title                String
  description          String?
  priority             String?   @default("Medium")
  status               String    @default("To Do") // To Do, In Progress, Review, Testing, Completed
  dueDate              DateTime?
  estimatedHours       Decimal?  @default(0)
  actualHours          Decimal?  @default(0)
  checklist            Json?
  attachments          Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  exceptions  AttendanceException[]
  adjustments AttendanceAdjustment[]
  overtimes   AttendanceOvertime[]

  @@index([companyId])
  @@index([projectId])
}

model Attendance {
  id                    String                 @id @default(uuid())
  companyId             String?
  company               Company?               @relation(fields: [companyId], references: [id])
  employeeId            String
  employee              Employee               @relation(fields: [employeeId], references: [id])
  date                  DateTime // Store just the date (YYYY-MM-DD)
  checkInTime           DateTime?              @map("checkIn")
  checkInLocation       String?
  checkOutTime          DateTime?              @map("checkOut")
  checkOutLocation      String?
  status                String // PRESENT, LATE, ABSENT, HALF_DAY, WEEKLY_OFF, OFF_DAY_WORK
  isLate                Boolean                @default(false)
  lateMinutes           Int                    @default(0)
  totalWorkingMinutes   Int?                   @default(0)
  earlyLeaveMinutes     Int?                   @default(0)
  overtimeMinutes       Int?                   @default(0)
  punishmentReason      String?
  reviewStatus          String?
  punishmentAmount      Decimal?               @default(0)
  latitude              Float?
  longitude             Float?
  wifiSsid              String?
  wifiBssid             String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  attendanceExceptions  AttendanceException[]
  attendanceAdjustments AttendanceAdjustment[]
  attendanceOvertimes   AttendanceOvertime[]

  @@unique([employeeId, date])
  @@index([companyId])
}

model AttendanceShiftAssignment {
  id            String    @id @default(uuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workShiftId   String
  workShift     WorkShift @relation(fields: [workShiftId], references: [id])
  effectiveDate DateTime
  endDate       DateTime?
  isRotation    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([employeeId])
}

model AttendanceException {
  id              String     @id @default(uuid())
  attendanceId    String
  attendance      Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type            String // LATE, EARLY_LEAVE, MISSING_CHECKIN, MISSING_CHECKOUT, HOLIDAY_WORK, WEEKEND_WORK
  durationMinutes Int        @default(0)
  reason          String?
  status          String     @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  task            Task?      @relation(fields: [taskId], references: [id])
  taskId          String?

  @@index([attendanceId])
  @@index([employeeId])
}

model AttendanceAdjustment {
  id            String     @id @default(uuid())
  attendanceId  String
  attendance    Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type          String // CORRECTION, OVERRIDE
  reason        String?
  requestedById String?
  approvedById  String?
  status        String     @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  task          Task?      @relation(fields: [taskId], references: [id])
  taskId        String?

  @@index([attendanceId])
  @@index([employeeId])
}

model AttendanceOvertime {
  id           String     @id @default(uuid())
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type         String // NORMAL, WEEKEND, HOLIDAY
  hours        Decimal    @default(0)
  rate         Decimal    @default(1.0)
  status       String     @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedById String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  task         Task?      @relation(fields: [taskId], references: [id])
  taskId       String?

  @@index([attendanceId])
  @@index([employeeId])
}

model AttendanceRoster {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workShiftId String
  workShift   WorkShift @relation(fields: [workShiftId], references: [id])
  date        DateTime
  status      String    @default("PLANNED") // PLANNED, ACTUAL
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([employeeId])
}

model AttendanceHolidayAssignment {
  id         String          @id @default(uuid())
  companyId  String
  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  holidayId  String
  holiday    HolidayCalendar @relation(fields: [holidayId], references: [id])
  date       DateTime
  status     String          @default("ACTIVE")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([companyId])
  @@index([employeeId])
}

model JobOpening {
  id               String          @id @default(uuid())
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobCode          String?
  title            String
  departmentId     String?
  department       Department?     @relation(fields: [departmentId], references: [id])
  designationId    String?
  designation      Designation?    @relation(fields: [designationId], references: [id])
  employmentTypeId String?
  employmentType   EmploymentType? @relation(fields: [employmentTypeId], references: [id])
  vacancies        Int             @default(1)
  openingDate      DateTime
  closingDate      DateTime?
  status           String          @default("OPEN") // OPEN, CLOSED, DRAFT
  createdById      String?
  user             User?           @relation(fields: [createdById], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  applications Application[]

  @@index([companyId])
}

model Applicant {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fullName    String
  email       String
  phone       String?
  dateOfBirth DateTime?
  resume      String?
  linkedin    String?
  portfolio   String?
  status      String    @default("NEW") // NEW, IN_PROGRESS, REJECTED, HIRED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  applications Application[]

  @@unique([companyId, email])
  @@index([companyId])
}

model Application {
  id           String     @id @default(uuid())
  jobOpeningId String
  jobOpening   JobOpening @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  applicantId  String
  applicant    Applicant  @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  currentStage String     @default("APPLIED") // APPLIED, SCREENING, SHORTLISTED, INTERVIEW, TECHNICAL, HR, OFFERED, HIRED, REJECTED, WITHDRAWN
  source       String?
  appliedAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  interviews Interview[]
  jobOffers  JobOffer[]

  @@unique([jobOpeningId, applicantId])
  @@index([jobOpeningId])
  @@index([applicantId])
}

model Interview {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          String // TECHNICAL, HR, CULTURAL
  date          DateTime
  interviewerId String
  interviewer   Employee    @relation(fields: [interviewerId], references: [id])
  location      String?
  onlineLink    String?
  status        String      @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  feedbacks InterviewFeedback[]

  @@index([applicationId])
  @@index([interviewerId])
}

model InterviewFeedback {
  id                 String    @id @default(uuid())
  interviewId        String
  interview          Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewerId      String
  interviewer        Employee  @relation(fields: [interviewerId], references: [id])
  technicalScore     Int?
  communicationScore Int?
  cultureScore       Int?
  overallScore       Int?
  recommendation     String? // HIRE, NO_HIRE, STRONG_HIRE
  comments           String?
  createdAt          DateTime  @default(now())

  @@index([interviewId])
  @@index([interviewerId])
}

model JobOffer {
  id             String       @id @default(uuid())
  applicationId  String
  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  salary         Decimal
  joiningDate    DateTime
  designationId  String?
  designation    Designation? @relation(fields: [designationId], references: [id])
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  status         String       @default("PENDING") // PENDING, ACCEPTED, REJECTED, WITHDRAWN
  offerLetterUrl String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([applicationId])
}

model LeaveRequest {
  id         String   @id @default(uuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String // CASUAL, SICK, UNPAID
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
}

model SalaryPayment {
  id             String    @id @default(uuid())
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id])
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id])
  month          Int // 1-12
  year           Int
  basicSalary    Decimal
  grossSalary    Decimal
  netSalary      Decimal
  paymentDate    DateTime?
  status         String    @default("PAID") // DRAFT, CALCULATED, SUBMITTED, APPROVED, PAID, LOCKED, ARCHIVED
  expenseId      String? // Link to Expense model record in Shohoj Ledger
  paymentMethod  String?
  transactionRef String?
  paymentNote    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  audits PayrollAudit[]

  @@index([companyId])
}

model SalaryDeduction {
  id         String   @id @default(uuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  month      Int
  year       Int
  type       String // LATE_FEE, UNPAID_LEAVE, OTHER
  amount     Decimal
  reason     String?
  createdAt  DateTime @default(now())

  @@index([companyId])
}

model Bonus {
  id         String   @id @default(uuid())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  month      Int
  year       Int
  type       String // PERFORMANCE, FESTIVAL, OTHER
  amount     Decimal
  reason     String?
