  salaryPayment   SalaryPayment @relation(fields: [salaryPaymentId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  role            String
  oldStatus       String?
  newStatus       String
  remarks         String?
  createdAt       DateTime      @default(now())

  @@index([companyId])
  @@index([salaryPaymentId])
}

model LedgerEntry {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  date        DateTime @default(now())
  voucherNo   String
  voucherType String

  referenceId String?
  module      String

  accountType String
  debit       Decimal @default(0)
  credit      Decimal @default(0)

  status      String  @default("COMPLETED")
  description String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // V1.3 General Ledger Engine Additions
  branchId           String?
  branch             Branch?           @relation(fields: [branchId], references: [id])
  journalEntryId     String?
  journalEntry       JournalEntry?     @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  journalEntryLineId String?
  journalEntryLine   JournalEntryLine? @relation(fields: [journalEntryLineId], references: [id], onDelete: Cascade)
  accountId          String?
  account            ChartOfAccount?   @relation(fields: [accountId], references: [id])
  entryDate          DateTime?
  runningBalance     Decimal?
  referenceType      String?

  @@index([companyId])
  @@index([date])
  @@index([voucherNo])
  @@index([accountId])
  @@index([entryDate])
  @@index([journalEntryId])
  @@index([module])
}

model ReportAudit {
  id         String   @id @default(uuid())
